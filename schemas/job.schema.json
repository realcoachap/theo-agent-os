{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/realcoachap/theo-agent-os/schemas/job.schema.json",
  "title": "Theo Agent OS Job Envelope",
  "description": "Theo Agent OS v0.1.0 - Noted by Theo - 2026-06-09. Input contract for routed worker jobs.",
  "type": "object",
  "required": ["job_id", "lane", "intent", "worker", "task", "context", "permissions", "verify", "budget"],
  "additionalProperties": false,
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "lane": {"type": "string", "minLength": 1},
    "intent": {"type": "string", "enum": ["build", "patch", "research", "review", "map", "content", "propose"]},
    "worker": {"type": "string", "minLength": 1},
    "model_profile": {"type": "string"},
    "task": {"type": "string", "minLength": 1},
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "graph": {"type": "string"},
        "spec": {"type": "string"},
        "agents_md": {"type": "boolean"},
        "blast_radius": {"type": "string"}
      }
    },
    "permissions": {
      "type": "object",
      "required": ["tier", "write", "deny", "network", "git_push"],
      "additionalProperties": false,
      "properties": {
        "tier": {"type": "string", "enum": ["read_only", "write_sandboxed", "write_trusted"]},
        "write": {"type": "array", "items": {"type": "string"}},
        "deny": {"type": "array", "items": {"type": "string"}},
        "network": {"type": "boolean"},
        "git_push": {"type": "boolean"}
      }
    },
    "verify": {
      "type": "object",
      "required": ["tests", "lint"],
      "additionalProperties": false,
      "properties": {
        "tests": {"type": ["string", "null"]},
        "lint": {"type": "boolean"}
      }
    },
    "budget": {
      "type": "object",
      "required": ["max_minutes", "max_tokens"],
      "additionalProperties": false,
      "properties": {
        "max_minutes": {"type": "integer", "minimum": 1},
        "max_tokens": {"type": "integer", "minimum": 1}
      }
    }
  }
}
