{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/realcoachap/theo-agent-os/schemas/result-envelope.schema.json",
  "title": "Theo Agent OS Result Envelope",
  "description": "Theo Agent OS v0.1.0 - Noted by Theo - 2026-06-09. Output contract for worker job results.",
  "type": "object",
  "required": ["job_id", "status", "state", "summary", "files_touched", "tests", "git", "artifacts", "memory_proposals"],
  "properties": {
    "job_id": {"type": "string"},
    "status": {"enum": ["success", "partial", "failed", "blocked"]},
    "state": {"enum": ["proposed", "approved", "running", "review", "shipped", "killed"]},
    "summary": {"type": "string"},
    "diff": {"type": "string"},
    "files_touched": {"type": "array", "items": {"type": "string"}},
    "tests": {"type": "object"},
    "git": {"type": "object"},
    "transcript": {"type": "string"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_type", "title", "summary", "path", "preview_kind", "worker", "source_job", "safe_to_render"],
        "properties": {
          "artifact_type": {"enum": ["report", "html", "doc", "image", "video", "code", "data"]},
          "title": {"type": "string"},
          "summary": {"type": "string"},
          "path": {"type": "string"},
          "preview_kind": {"enum": ["text", "html", "image", "none"]},
          "worker": {"type": "string"},
          "source_job": {"type": "string"},
          "safe_to_render": {"type": "boolean"}
        }
      }
    },
    "memory_proposals": {"type": "array", "items": {"type": "string"}},
    "followups": {"type": "array", "items": {"type": "string"}},
    "cost": {"type": "object"}
  }
}

