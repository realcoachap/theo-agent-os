{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/realcoachap/theo-agent-os/schemas/result.schema.json",
  "title": "Theo Agent OS Result Envelope",
  "description": "Theo Agent OS v0.1.0 - Noted by Theo - 2026-06-09. Output contract for worker job results.",
  "type": "object",
  "required": ["job_id", "status", "state", "summary", "diff", "files_touched", "tests", "git", "transcript", "artifacts", "memory_proposals", "followups", "cost"],
  "additionalProperties": false,
  "properties": {
    "job_id": {"type": "string"},
    "status": {"type": "string", "enum": ["success", "partial", "failed", "blocked"]},
    "state": {"type": "string", "enum": ["proposed", "approved", "running", "review", "shipped", "killed"]},
    "summary": {"type": "string", "minLength": 1, "maxLength": 900},
    "diff": {"type": ["string", "null"]},
    "files_touched": {"type": "array", "items": {"type": "string"}},
    "tests": {
      "type": "object",
      "required": ["ran", "passed", "failed"],
      "additionalProperties": false,
      "properties": {
        "ran": {"type": "boolean"},
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0}
      }
    },
    "git": {
      "type": "object",
      "required": ["branch", "dirty", "commits"],
      "additionalProperties": false,
      "properties": {
        "branch": {"type": "string"},
        "dirty": {"type": "boolean"},
        "commits": {"type": "array", "items": {"type": "string"}}
      }
    },
    "transcript": {"type": "string"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_type", "title", "summary", "path", "preview_kind", "worker", "source_job", "safe_to_render"],
        "additionalProperties": false,
        "properties": {
          "artifact_type": {"type": "string", "enum": ["report", "html", "doc", "image", "video", "code", "data"]},
          "title": {"type": "string"},
          "summary": {"type": "string"},
          "path": {"type": "string"},
          "preview_kind": {"type": "string", "enum": ["text", "html", "image", "none"]},
          "worker": {"type": "string"},
          "source_job": {"type": "string"},
          "safe_to_render": {"type": "boolean"}
        }
      }
    },
    "memory_proposals": {"type": "array", "items": {"type": "string"}},
    "followups": {"type": "array", "items": {"type": "string"}},
    "cost": {
      "type": "object",
      "required": ["tokens", "minutes"],
      "additionalProperties": false,
      "properties": {
        "tokens": {"type": "integer", "minimum": 0},
        "minutes": {"type": "number", "minimum": 0}
      }
    }
  }
}
