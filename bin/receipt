#!/usr/bin/env python3
"""Theo Agent OS receipt v0.3.0 - Noted by Theo - 2026-06-10.

Render a result envelope into the short text Coach should see in Telegram.
"""

from __future__ import annotations

import json
import signal
import sys
from pathlib import Path


signal.signal(signal.SIGPIPE, signal.SIG_DFL)
REPO_ROOT = Path(__file__).resolve().parents[1]


def lane_path(value: str) -> Path:
    if value == "self":
        return REPO_ROOT
    return Path(value).expanduser().resolve()


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: bin/receipt <runs/.../result.json>", file=sys.stderr)
        return 2
    result_path = Path(sys.argv[1])
    result = json.loads(result_path.read_text(encoding="utf-8"))
    job_path = result_path.parent / "job.json"
    job = json.loads(job_path.read_text(encoding="utf-8")) if job_path.exists() else {}
    tests = result.get("tests", {})
    git = result.get("git", {})
    artifacts = result.get("artifacts", [])
    proposals = result.get("memory_proposals", [])
    branch = git.get("branch", "")

    lines = [
        f"STATUS: {result.get('status', 'unknown')} / {result.get('state', 'unknown')}",
        f"summary: {result.get('summary', '')}",
        f"tests: ran={tests.get('ran', False)} passed={tests.get('passed', 0)} failed={tests.get('failed', 0)}",
        f"branch: {branch or '(none)'} dirty={git.get('dirty', False)}",
        f"files_touched: {len(result.get('files_touched', []))}",
    ]
    for artifact in artifacts[:8]:
        lines.append(f"artifact: {artifact.get('title', 'untitled')} -> {artifact.get('path', '')}")
    for proposal in proposals[:5]:
        lines.append(f"PROPOSED: {proposal}")
    if branch.startswith("agent/"):
        lane = lane_path(str(job.get("lane", "self")))
        worktree = lane / ".worktrees" / str(result.get("job_id", result_path.parent.name))
        lines.append(f"undo: git worktree remove {worktree} && git branch -D {branch}")
    lines.append(f"result: {result_path}")
    print("\n".join(lines[:20]))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
