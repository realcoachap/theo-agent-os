#!/usr/bin/env python3
"""Theo Agent OS Mouth intake v0.4.0 - Noted by Theo - 2026-06-10.

Compile a trusted phone/OpenClaw command envelope into the canonical job
schema, optionally run dispatch, and render the same receipt Coach already
trusts. Mouth is intentionally not a natural-language shell bridge: the chat
layer must provide structured JSON and dispatch still owns all worker gates.
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
COMMAND_SCHEMA = REPO_ROOT / "schemas" / "command.schema.json"
JOB_SCHEMA = REPO_ROOT / "schemas" / "job.schema.json"
REGISTRY = REPO_ROOT / "registry" / "workers.json"
INBOX = REPO_ROOT / "jobs" / "inbox"
RUNS = REPO_ROOT / "runs"
VERSION = "0.4.0"

VERIFY_PROFILES = {
    "none": None,
    "schema_smoke": "python3 -m json.tool \"$JOB_PATH\" >/dev/null",
    "shot3_selftest": "test -s fixtures/shot3-write-target.txt && test -L fixtures/git-common-link",
}


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z")


def rel(path: Path) -> str:
    try:
        return str(path.resolve().relative_to(REPO_ROOT))
    except ValueError:
        return str(path)


def run(cmd: list[str], cwd: Path | None = None, env: dict[str, str] | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, env=env, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)


def load_json(path: Path) -> Any:
    return json.loads(path.read_text(encoding="utf-8"))


def write_json(path: Path, data: object) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def validator_errors(schema: Path, target: Path) -> list[str]:
    proc = run([str(REPO_ROOT / "bin" / "validate"), str(schema), str(target)])
    if proc.returncode == 0:
        return []
    return [line.strip() for line in (proc.stderr or proc.stdout).splitlines() if line.strip()]


def registry_map() -> dict[str, dict[str, Any]]:
    data = load_json(REGISTRY)
    return {worker["name"]: worker for worker in data.get("workers", [])}


def fail(message: str, code: int = 2) -> int:
    print(message, file=sys.stderr)
    return code


def command_dir(command_id: str) -> Path:
    return INBOX / command_id


def mouth_record(command: dict[str, Any], job: dict[str, Any], state: str, summary: str, out_dir: Path) -> dict[str, Any]:
    return {
        "version": VERSION,
        "command_id": command["command_id"],
        "job_id": job["job_id"],
        "state": state,
        "summary": summary,
        "mode": command["execution"]["mode"],
        "source": {
            "channel": command["source"]["channel"],
            "message_id": command["source"].get("message_id", ""),
            "sender_label": command["source"]["sender_label"],
            "trusted": command["source"]["trusted"],
        },
        "job_path": rel(out_dir / "job.json"),
        "command_path": rel(out_dir / "command.json"),
        "result_path": "",
        "receipt_path": "",
        "receipt_preview": "",
        "created_at": utc_now(),
        "updated_at": utc_now(),
    }


def semantic_errors(command: dict[str, Any], worker: dict[str, Any]) -> list[str]:
    errors: list[str] = []
    mode = command["execution"]["mode"]
    tier = command["permissions"]["tier"]
    approvals = command["approvals"]
    source = command["source"]

    if mode != "draft" and not source.get("trusted"):
        errors.append("non-draft commands require source.trusted=true")
    if command["permissions"].get("git_push") is not False:
        errors.append("Mouth refuses git_push=true; dispatch jobs must keep git_push false")
    if command["permissions"].get("network") is not False:
        errors.append("Mouth v0.4.0 refuses network=true; add a later reviewed lane for networked jobs")
    if tier != "read_only" and mode != "draft":
        if approvals.get("operator") is not True:
            errors.append("write dispatch requires approvals.operator=true")
        if approvals.get("write") is not True:
            errors.append("write dispatch requires approvals.write=true")
    if mode == "dispatch_real":
        if worker.get("cost_tier") != "free" and approvals.get("spend") is not True:
            errors.append("dispatch_real requires approvals.spend=true for non-free workers")
        enable_env = worker.get("enable_env")
        if isinstance(enable_env, str) and os.environ.get(enable_env) != "1":
            errors.append(f"dispatch_real requires {enable_env}=1")
    if mode == "dispatch_selftest" and worker.get("adapter_selftest") is not True:
        errors.append("dispatch_selftest requires a selftest-capable worker")
    if command["verify_profile"] not in VERIFY_PROFILES:
        errors.append(f"unknown verify_profile: {command['verify_profile']}")
    return errors


def compile_job(command: dict[str, Any]) -> dict[str, Any]:
    verify_tests = VERIFY_PROFILES[command["verify_profile"]]
    return {
        "job_id": command.get("job_id") or command["command_id"],
        "lane": command["lane"],
        "intent": command["intent"],
        "worker": command["worker"],
        "model_profile": command.get("model_profile", "default"),
        "task": command["task"],
        "context": command["context"],
        "permissions": command["permissions"],
        "verify": {"tests": verify_tests, "lint": False},
        "budget": command["budget"],
    }


def dispatch_job(job_path: Path, command: dict[str, Any]) -> tuple[int, str, str]:
    env = dict(os.environ)
    if command["execution"]["mode"] == "dispatch_selftest":
        env["THEO_ADAPTER_SELFTEST"] = "1"
    proc = run([str(REPO_ROOT / "bin" / "dispatch"), str(job_path)], cwd=REPO_ROOT, env=env)
    result_path = proc.stdout.strip().splitlines()[-1] if proc.stdout.strip() else ""
    receipt = ""
    if result_path:
        receipt_proc = run([str(REPO_ROOT / "bin" / "receipt"), result_path], cwd=REPO_ROOT)
        receipt = receipt_proc.stdout if receipt_proc.returncode == 0 else receipt_proc.stderr
    return proc.returncode, result_path, receipt


def append_mouth_index(record: dict[str, Any]) -> None:
    RUNS.mkdir(exist_ok=True)
    with (RUNS / "mouth-index.jsonl").open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, sort_keys=True) + "\n")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Compile a Mouth command into a Theo job envelope.")
    parser.add_argument("command", help="Path to command envelope JSON.")
    parser.add_argument("--dispatch", action="store_true", help="Run dispatch after compiling. Refuses execution.mode=draft.")
    parser.add_argument("--json", action="store_true", help="Print the Mouth record as JSON.")
    parser.add_argument("--receipt", action="store_true", help="Print receipt text after dispatch.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    command_path = Path(args.command).expanduser().resolve()
    if not command_path.exists():
        return fail(f"command not found: {command_path}")

    errors = validator_errors(COMMAND_SCHEMA, command_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    command = load_json(command_path)
    workers = registry_map()
    if command["worker"] not in workers:
        return fail(f"unknown worker: {command['worker']}")
    worker = workers[command["worker"]]
    semantic = semantic_errors(command, worker)
    if semantic:
        for error in semantic:
            print(f"semantic error: {error}", file=sys.stderr)
        return 2
    if args.dispatch and command["execution"]["mode"] == "draft":
        return fail("cannot --dispatch a draft command; use dispatch_selftest or dispatch_real")

    job = compile_job(command)
    out_dir = command_dir(command["command_id"])
    out_dir.mkdir(parents=True, exist_ok=True)
    write_json(out_dir / "command.json", command)
    write_json(out_dir / "job.json", job)
    job_errors = validator_errors(JOB_SCHEMA, out_dir / "job.json")
    if job_errors:
        for error in job_errors:
            print(error, file=sys.stderr)
        return 2

    record = mouth_record(command, job, "compiled", "Command compiled into a canonical job envelope.", out_dir)
    if args.dispatch:
        record["state"] = "running"
        record["summary"] = "Dispatch started from Mouth command."
        record["updated_at"] = utc_now()
        write_json(out_dir / "mouth.json", record)
        code, result_path, receipt = dispatch_job(out_dir / "job.json", command)
        result_status = "failed"
        if result_path:
            result_file = Path(result_path).expanduser()
            if not result_file.is_absolute():
                result_file = REPO_ROOT / result_file
            if result_file.exists():
                result = load_json(result_file)
                result_status = str(result.get("status", "failed"))
                record["result_path"] = rel(result_file)
        record["state"] = "review" if result_status in {"success", "partial", "blocked", "failed"} else result_status
        record["summary"] = f"Dispatch finished with result status {result_status}."
        if receipt:
            receipt_path = out_dir / "receipt.txt"
            receipt_path.write_text(receipt, encoding="utf-8")
            record["receipt_path"] = rel(receipt_path)
            record["receipt_preview"] = receipt[:1200]
        record["updated_at"] = utc_now()
        write_json(out_dir / "mouth.json", record)
        append_mouth_index(record)
        if args.receipt:
            print(receipt.rstrip())
        elif args.json:
            print(json.dumps(record, indent=2, sort_keys=True))
        else:
            print(record["result_path"] or rel(out_dir / "mouth.json"))
        return code

    write_json(out_dir / "mouth.json", record)
    append_mouth_index(record)
    if args.json:
        print(json.dumps(record, indent=2, sort_keys=True))
    else:
        print(rel(out_dir / "job.json"))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
