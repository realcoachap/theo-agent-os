#!/usr/bin/env python3
"""Theo Agent OS Foundry dispatcher v0.3.0 - Noted by Theo - 2026-06-10.

Routes one job envelope to one thin adapter, writes an append-only run record,
and enforces the early gates before any worker sees the task. Exit codes are
canonical for operator glue: 0 success, 2 validation/semantic rejection before
a run exists, 3 blocked, 4 failed, and 5 partial.

Shot 3 adds the first write-run safety rails: budget timeouts, per-lane writer
locks, blocked-action evidence, and enough adapter context to keep worktree
writes reviewable before any external CLI is allowed to touch source.
"""

from __future__ import annotations

import json
import os
import signal
import shutil
import subprocess
import sys
import time
from datetime import datetime, timezone
from hashlib import sha256
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
SCHEMA_JOB = REPO_ROOT / "schemas" / "job.schema.json"
SCHEMA_RESULT = REPO_ROOT / "schemas" / "result.schema.json"
REGISTRY = REPO_ROOT / "registry" / "workers.json"
RUNS = REPO_ROOT / "runs"
LOCKS = RUNS / "locks"
TIER_ORDER = {"read_only": 0, "write_sandboxed": 1, "write_trusted": 2}
STATUS_EXIT = {"success": 0, "partial": 5, "blocked": 3, "failed": 4}
STRIPPED_CHILD_ENV = {"ANTHROPIC_BASE_URL", "ANTHROPIC_API_KEY"}
TIMEOUT_GRACE_SECONDS = 5
DEFAULT_LOCK_STALE_SECONDS = 60 * 60 * 2


def run(cmd: list[str], cwd: Path | None = None, check: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, check=check, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)


def load_json(path: Path) -> Any:
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def validator_errors(schema: Path, target: Path) -> list[str]:
    proc = run([str(REPO_ROOT / "bin" / "validate"), str(schema), str(target)])
    if proc.returncode == 0:
        return []
    return [line.strip() for line in (proc.stderr or proc.stdout).splitlines() if line.strip()]


def fail(message: str, code: int = 2) -> int:
    print(message, file=sys.stderr)
    return code


def registry_map() -> dict[str, dict[str, Any]]:
    data = load_json(REGISTRY)
    return {worker["name"]: worker for worker in data.get("workers", [])}


def worker_env(worker: dict[str, Any], source_env: dict[str, str] | None = None) -> tuple[dict[str, str], list[str]]:
    """Resolve worker env targets from explicit $VAR caller references."""
    source_env = source_env or os.environ
    resolved: dict[str, str] = {}
    errors: list[str] = []
    for target_key, source_ref in worker.get("env_profile", {}).items():
        if not isinstance(source_ref, str) or not source_ref.startswith("$") or len(source_ref) == 1:
            errors.append(f"env_profile.{target_key} must reference a calling env var as $VAR")
            continue
        source_name = source_ref[1:]
        if source_name not in source_env or source_env[source_name] == "":
            errors.append(f"missing required calling env var {source_name} for {target_key}")
            continue
        resolved[target_key] = source_env[source_name]
    return resolved, errors


def child_env_base(source_env: dict[str, str] | None = None) -> dict[str, str]:
    """Start child env from caller env, but strip route-changing Anthropic vars."""
    env = dict(source_env or os.environ)
    for key in STRIPPED_CHILD_ENV:
        env.pop(key, None)
    return env


def lane_path(lane: str) -> Path:
    if lane == "self":
        return REPO_ROOT
    return Path(lane).expanduser().resolve()


def rel(path: Path) -> str:
    try:
        return str(path.resolve().relative_to(REPO_ROOT))
    except ValueError:
        return str(path)


def ensure_context_path(base: Path, value: str) -> Path:
    path = Path(value).expanduser()
    if not path.is_absolute():
        candidate = (base / path).resolve()
        if candidate.exists():
            return candidate
        return (REPO_ROOT / path).resolve()
    return path.resolve()


def semantically_validate(job: dict[str, Any], worker: dict[str, Any], lane: Path) -> list[str]:
    errors: list[str] = []
    tier = job["permissions"]["tier"]
    ceiling = worker.get("permission_ceiling", "read_only")
    if TIER_ORDER[tier] > TIER_ORDER.get(ceiling, 0):
        errors.append(f"permission tier {tier} exceeds worker ceiling {ceiling}")
    if job["permissions"].get("git_push") is not False:
        errors.append("permissions.git_push must be false")
    if not lane.exists() or not lane.is_dir():
        errors.append(f"lane path does not exist: {lane}")
    if tier != "read_only":
        context = job.get("context", {})
        for key in ("graph", "spec", "blast_radius"):
            if not context.get(key):
                errors.append(f"context.{key} is required for write jobs")
        if context.get("agents_md") is not True:
            errors.append("context.agents_md must be true for write jobs")
        if context.get("graph"):
            graph = ensure_context_path(lane, context["graph"])
            if not graph.exists():
                errors.append(f"context.graph does not exist: {graph}")
        if context.get("spec"):
            spec = ensure_context_path(lane, context["spec"])
            if not spec.exists():
                errors.append(f"context.spec does not exist: {spec}")
    return errors


def graph_is_stale(graph: Path, lane: Path) -> tuple[bool, str]:
    head_proc = run(["git", "rev-parse", "HEAD"], cwd=lane)
    if head_proc.returncode != 0:
        return False, "lane is not a git repo; staleness gate skipped"
    current_head = head_proc.stdout.strip()
    head_file = graph.parent / ".head"
    if head_file.exists():
        recorded = head_file.read_text(encoding="utf-8").strip()
        if recorded != current_head:
            return True, f"graph .head {recorded or '(empty)'} does not match HEAD {current_head}"
        return False, "graph .head matches HEAD"
    graph_mtime = int(graph.stat().st_mtime)
    commit_time_proc = run(["git", "log", "-1", "--format=%ct"], cwd=lane)
    if commit_time_proc.returncode == 0:
        commit_time = int(commit_time_proc.stdout.strip())
        if graph_mtime < commit_time:
            return True, "graph mtime is older than last commit and no .head stamp exists"
    return False, "graph has no .head; mtime fallback accepted"


def new_run(job: dict[str, Any]) -> Path:
    today = datetime.now().strftime("%Y-%m-%d")
    run_dir = RUNS / today / job["job_id"]
    run_dir.mkdir(parents=True, exist_ok=False)
    return run_dir


def existing_run(job_id: str) -> Path | None:
    """Job ids are append-only identities; one id may only create one run."""
    if not RUNS.exists():
        return None
    for date_dir in sorted(RUNS.iterdir()):
        if not date_dir.is_dir():
            continue
        candidate = date_dir / job_id
        if candidate.exists():
            return candidate
    return None


def write_result(run_dir: Path, result: dict[str, Any]) -> Path:
    blocked_path = run_dir / "blocked.log"
    blocked_rel = rel(blocked_path)
    artifacts = result.setdefault("artifacts", [])
    if blocked_path.exists() and isinstance(artifacts, list) and not any(
        isinstance(item, dict) and item.get("path") == blocked_rel for item in artifacts
    ):
        artifacts.append({
            "artifact_type": "data",
            "title": "Denied action log",
            "summary": "JSONL rows for blocked writes, commands, locks, or dispatch guards.",
            "path": blocked_rel,
            "preview_kind": "text",
            "worker": "dispatch",
            "source_job": result.get("job_id", run_dir.name),
            "safe_to_render": True,
        })
    result_path = run_dir / "result.json"
    result_path.write_text(json.dumps(result, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    return result_path


def append_blocked_log(run_dir: Path, tool: str, path_or_cmd: str, rule: str) -> None:
    """Record a denied action in the Shot 3 JSONL evidence contract."""
    row = {
        "ts": datetime.now(timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z"),
        "tool": tool,
        "path_or_cmd": path_or_cmd,
        "rule": rule,
    }
    with (run_dir / "blocked.log").open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(row, sort_keys=True) + "\n")


def append_index(run_dir: Path, job: dict[str, Any], result: dict[str, Any], started: float) -> None:
    RUNS.mkdir(exist_ok=True)
    entry = {
        "job_id": job["job_id"],
        "date": datetime.now().strftime("%Y-%m-%d"),
        "lane": job["lane"],
        "worker": job["worker"],
        "status": result["status"],
        "state": result["state"],
        "run_dir": rel(run_dir),
        "created_at": datetime.fromtimestamp(started).isoformat(timespec="seconds"),
        "finished_at": datetime.now().isoformat(timespec="seconds"),
        "summary": result["summary"],
    }
    with (RUNS / "index.jsonl").open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(entry, sort_keys=True) + "\n")


def base_result(job: dict[str, Any], status: str, summary: str, run_dir: Path) -> dict[str, Any]:
    branch_proc = run(["git", "branch", "--show-current"], cwd=lane_path(job["lane"]))
    branch = branch_proc.stdout.strip() if branch_proc.returncode == 0 else ""
    return {
        "job_id": job["job_id"],
        "status": status,
        "state": "review" if status in {"success", "partial", "blocked", "failed"} else "running",
        "summary": summary,
        "diff": None,
        "files_touched": [],
        "tests": {"ran": False, "passed": 0, "failed": 0},
        "git": {"branch": branch, "dirty": False, "commits": []},
        "transcript": rel(run_dir / "transcript.md"),
        "artifacts": [],
        "memory_proposals": [],
        "followups": [],
        "cost": {"tokens": 0, "minutes": 0},
    }


def is_write_job(job: dict[str, Any]) -> bool:
    return job["permissions"]["tier"] != "read_only"


def lock_stale_seconds(job: dict[str, Any]) -> int:
    override = os.environ.get("THEO_LOCK_STALE_SECONDS")
    if override:
        try:
            return max(1, int(override))
        except ValueError:
            return DEFAULT_LOCK_STALE_SECONDS
    budget_seconds = int(job.get("budget", {}).get("max_minutes", 1)) * 60
    return max(DEFAULT_LOCK_STALE_SECONDS, budget_seconds + TIMEOUT_GRACE_SECONDS + 60)


def lane_lock_path(lane: Path) -> Path:
    key = sha256(str(lane.resolve()).encode("utf-8")).hexdigest()[:24]
    return LOCKS / f"{key}.lock"


def pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False


def read_lock(path: Path) -> dict[str, Any]:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def stale_lock_reason(path: Path, job: dict[str, Any]) -> str | None:
    data = read_lock(path)
    pid = data.get("pid")
    ts = data.get("ts")
    if not isinstance(pid, int):
        return "lock file has no integer pid"
    if not pid_alive(pid):
        return f"lock owner pid {pid} is not alive"
    if isinstance(ts, (int, float)) and time.time() - float(ts) > lock_stale_seconds(job):
        return f"lock age exceeded {lock_stale_seconds(job)} seconds"
    return None


def acquire_lane_lock(job: dict[str, Any], lane: Path, run_dir: Path) -> tuple[Path | None, str | None]:
    """Atomically acquire the single-writer lock for a write lane."""
    LOCKS.mkdir(parents=True, exist_ok=True)
    path = lane_lock_path(lane)
    payload = {
        "pid": os.getpid(),
        "job_id": job["job_id"],
        "ts": time.time(),
        "lane": str(lane),
        "run_dir": rel(run_dir),
    }
    while True:
        try:
            fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o644)
        except FileExistsError:
            reason = stale_lock_reason(path, job)
            if reason:
                append_blocked_log(run_dir, "dispatch", rel(path), f"stale_lane_lock_recovered: {reason}")
                path.unlink(missing_ok=True)
                continue
            data = read_lock(path)
            holder = data.get("job_id", "unknown")
            return None, f"Lane lock is held by active job {holder}; refusing concurrent write dispatch."
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(json.dumps(payload, indent=2, sort_keys=True) + "\n")
        return path, None


def release_lane_lock(path: Path | None, job_id: str) -> None:
    if not path:
        return
    data = read_lock(path)
    if data.get("job_id") == job_id and data.get("pid") == os.getpid():
        path.unlink(missing_ok=True)


def budget_seconds(job: dict[str, Any]) -> int:
    return max(1, int(job["budget"]["max_minutes"])) * 60


def run_adapter(adapter: Path, cwd: Path, env: dict[str, str], timeout: int) -> tuple[subprocess.CompletedProcess[str], bool]:
    """Run an adapter with SIGTERM grace before SIGKILL on budget expiry."""
    proc = subprocess.Popen(
        [str(adapter)],
        cwd=cwd,
        text=True,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        start_new_session=True,
    )
    try:
        stdout, stderr = proc.communicate(timeout=timeout)
        return subprocess.CompletedProcess([str(adapter)], proc.returncode, stdout, stderr), False
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGTERM)
        except ProcessLookupError:
            pass
        try:
            stdout, stderr = proc.communicate(timeout=TIMEOUT_GRACE_SECONDS)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(proc.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
            stdout, stderr = proc.communicate()
        return subprocess.CompletedProcess([str(adapter)], -signal.SIGTERM, stdout or "", stderr or ""), True


def install_hook(repo: Path) -> int:
    repo = repo.expanduser().resolve()
    git_dir_proc = run(["git", "rev-parse", "--git-dir"], cwd=repo)
    if git_dir_proc.returncode != 0:
        return fail(f"not a git repo: {repo}")
    git_dir = (repo / git_dir_proc.stdout.strip()).resolve()
    hooks_dir = git_dir / "hooks"
    hooks_dir.mkdir(parents=True, exist_ok=True)
    target = hooks_dir / "post-commit"
    shutil.copy2(REPO_ROOT / "hooks" / "post-commit", target)
    target.chmod(0o755)
    print(f"installed hook: {target}")
    return 0


def maybe_worktree(job: dict[str, Any], lane: Path) -> Path | None:
    if job["permissions"]["tier"] == "read_only":
        return None
    worktree = lane / ".worktrees" / job["job_id"]
    branch = f"agent/{job['job_id']}"
    worktree.parent.mkdir(exist_ok=True)
    proc = run(["git", "worktree", "add", "-b", branch, str(worktree), "HEAD"], cwd=lane)
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip())
    return worktree


def main() -> int:
    if len(sys.argv) == 3 and sys.argv[1] == "--install-hook":
        return install_hook(Path(sys.argv[2]))
    if len(sys.argv) != 2:
        print("usage: bin/dispatch <job.json> OR bin/dispatch --install-hook <repo-path>", file=sys.stderr)
        return 2

    job_path = Path(sys.argv[1]).expanduser().resolve()
    if not job_path.exists():
        return fail(f"job not found: {job_path}")
    errors = validator_errors(SCHEMA_JOB, job_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    job = load_json(job_path)
    if job.get("model_profile") is None:
        job["model_profile"] = "default"
    workers = registry_map()
    if job["worker"] == "auto":
        if job["intent"] in {"map", "review", "research"} and job["permissions"]["tier"] == "read_only":
            job["worker"] = "graphify"
        else:
            return fail("auto worker can only resolve read_only map/review/research jobs in Shot 1")
    if job["worker"] not in workers:
        return fail(f"unknown worker: {job['worker']}")
    worker = workers[job["worker"]]
    lane = lane_path(job["lane"])
    duplicate = existing_run(job["job_id"])
    if duplicate:
        return fail(f"job_id already has a run under {rel(duplicate)}; job_ids are single-use, mint a new one", 2)
    semantic_errors = semantically_validate(job, worker, lane)
    if semantic_errors:
        for error in semantic_errors:
            print(f"semantic error: {error}", file=sys.stderr)
        return 2

    started = time.time()
    run_dir = new_run(job)
    (run_dir / "job.json").write_text(json.dumps(job, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    (run_dir / "meta.json").write_text(json.dumps({
        "started_at": datetime.now().isoformat(timespec="seconds"),
        "repo": str(REPO_ROOT),
        "blocked_log": rel(run_dir / "blocked.log"),
        "timeout_seconds": budget_seconds(job),
    }, indent=2, sort_keys=True) + "\n", encoding="utf-8")

    graph_value = job.get("context", {}).get("graph")
    if graph_value:
        graph = ensure_context_path(lane, graph_value)
        stale, reason = graph_is_stale(graph, lane)
        if stale:
            result = base_result(job, "blocked", f"Graph freshness gate blocked this job: {reason}.", run_dir)
            result["transcript"] = rel(run_dir / "transcript.md")
            (run_dir / "transcript.md").write_text(reason + "\n", encoding="utf-8")
            result_path = write_result(run_dir, result)
            append_index(run_dir, job, result, started)
            print(result_path)
            return 3

    resolved_env, env_errors = worker_env(worker)
    if env_errors:
        summary = "Worker environment profile blocked launch: " + "; ".join(env_errors)
        result = base_result(job, "blocked", summary, run_dir)
        (run_dir / "transcript.md").write_text(summary + "\n", encoding="utf-8")
        result_path = write_result(run_dir, result)
        append_index(run_dir, job, result, started)
        print(result_path)
        return 3

    adapter_ref = worker.get("adapter") or f"adapters/{job['worker']}.sh"
    adapter = (REPO_ROOT / str(adapter_ref)).resolve()
    if REPO_ROOT not in adapter.parents:
        return fail(f"adapter path escapes repo root: {adapter_ref}")
    if not adapter.exists():
        result = base_result(job, "blocked", f"Adapter is not implemented for worker {job['worker']}.", run_dir)
        result_path = write_result(run_dir, result)
        append_index(run_dir, job, result, started)
        print(result_path)
        return 3

    lock_path: Path | None = None
    if is_write_job(job):
        lock_path, lock_error = acquire_lane_lock(job, lane, run_dir)
        if lock_error:
            append_blocked_log(run_dir, "dispatch", str(lane), "lane_lock_active")
            result = base_result(job, "blocked", lock_error, run_dir)
            result_path = write_result(run_dir, result)
            append_index(run_dir, job, result, started)
            print(result_path)
            return 3

    try:
        worktree = maybe_worktree(job, lane)
    except RuntimeError as exc:
        result = base_result(job, "blocked", f"Could not create worktree: {exc}", run_dir)
        result_path = write_result(run_dir, result)
        append_index(run_dir, job, result, started)
        print(result_path)
        release_lane_lock(lock_path, job["job_id"])
        return 3

    env = child_env_base()
    env.update({
        "JOB_PATH": str(run_dir / "job.json"),
        "RUN_DIR": str(run_dir),
        "RUN_DIR_REL": rel(run_dir),
        "LANE_PATH": str(lane),
        "WORKTREE": str(worktree or ""),
        "REPO_ROOT": str(REPO_ROOT),
        "WORKER_NAME": job["worker"],
        "STARTED_EPOCH": str(started),
        "THEO_BUDGET_SECONDS": str(budget_seconds(job)),
        "THEO_BLOCKED_LOG": str(run_dir / "blocked.log"),
    })
    env.update(resolved_env)
    try:
        proc, timed_out = run_adapter(adapter, lane, env, budget_seconds(job))
        (run_dir / "adapter.stdout.log").write_text(proc.stdout, encoding="utf-8")
        (run_dir / "adapter.stderr.log").write_text(proc.stderr, encoding="utf-8")
        result_path = run_dir / "result.json"
        if timed_out:
            append_blocked_log(run_dir, "dispatch", str(adapter), f"budget.max_minutes timeout after {job['budget']['max_minutes']} minute(s)")
            result = base_result(
                job,
                "failed",
                f"Adapter {job['worker']} exceeded budget.max_minutes={job['budget']['max_minutes']}; SIGTERM grace was applied before the run was failed.",
                run_dir,
            )
            result["transcript"] = rel(run_dir / "adapter.stderr.log")
            write_result(run_dir, result)
        elif not result_path.exists():
            result = base_result(job, "failed", f"Adapter {job['worker']} did not write result.json.", run_dir)
            result["transcript"] = rel(run_dir / "adapter.stderr.log")
            write_result(run_dir, result)
        result_errors = validator_errors(SCHEMA_RESULT, result_path)
        if result_errors:
            bad = result_path.read_text(encoding="utf-8") if result_path.exists() else ""
            (run_dir / "invalid-result.json").write_text(bad, encoding="utf-8")
            result = base_result(job, "failed", "Adapter wrote an invalid result envelope; see invalid-result.json.", run_dir)
            result["transcript"] = rel(run_dir / "adapter.stderr.log")
            write_result(run_dir, result)
        result = load_json(result_path)
        append_index(run_dir, job, result, started)
        print(result_path)
        return STATUS_EXIT.get(result["status"], 4)
    finally:
        release_lane_lock(lock_path, job["job_id"])


if __name__ == "__main__":
    raise SystemExit(main())
