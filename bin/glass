<script>
const tabs = ["Mission Control", "Control", "Runs", "Mouth", "Artifacts", "Repo Maps", "Specs", "Memory Proposals", "Workers", "Security"];
const mobilePrimaryTabs = ["Mission Control", "Control", "Runs", "Artifacts"];
let current = "Mission Control";
let appState = null;

// --- Live-state sync (v0.5.0) ---------------------------------------------
// WHY: the admin door needs to feel live without yanking the view out from
// under the operator. We poll only when the tab is visible, only re-render when
// the meaningful state signature changes, and we defer (never clobber) a render
// while the operator has a run detail or artifact preview open.
const POLL_MS = 4000;
let live = true;            // auto-refresh on/off (Pause toggle)
let lastSig = null;         // signature of the last rendered state
let pendingSig = null;      // newer signature held back behind an interaction lock
let interactionLock = false; // true while a run detail / artifact preview is open
let openRunId = null;       // job_id of the open run detail, so it survives refresh
let syncedAt = 0;           // epoch ms of last successful fetch
let connError = false;      // last fetch failed
let pollTimer = null;

// Signature deliberately excludes generated_at so a snapshot with no real
// change does not trigger a re-render every few seconds.
function stateSignature(s) {
  if (!s) return "";
  const runs = (s.runs || []).map(r => `${r.job_id}:${r.status}:${r.state}:${r.finished_at || ""}`);
  const mouth = (s.mouth || []).map(m => `${m.command_id || m.id || ""}:${m.state || ""}:${(m.delivery || {}).status || ""}`);
  const sec = (((s.security || {}).items) || []).map(i => `${i.id}:${i.checked ? 1 : 0}`);
  const props = (s.memory_proposals || []).map(p => p.id);
  const reg = (((s.workers || {}).registry || {}).workers || []).map(w => `${w.name}:${w.status || ""}`);
  const control = (s.control_nodes || []).map(n => `${n.id}:${n.status}:${n.enabled ? 1 : 0}:${n.route || ""}`);
  const controlReceipts = (s.control_receipts || []).map(r => `${r.id}:${r.status}:${r.created_at || ""}`);
  const op = (s.workers || {}).operator || {};
  return JSON.stringify({runs, mouth, sec, props, reg, op: `${op.up ? 1 : 0}:${op.stale ? 1 : 0}`,
    control, controlReceipts, auth: (s.admin || {}).authenticated, writes: s.writes_enabled});
}

function esc(v) {
  return String(v ?? "").replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function cls(status) { return ["success","partial","blocked","failed"].includes(status) ? status : ""; }
function short(id) { return String(id || "").slice(0, 8); }
function receiptLabel(id) {
  const value = String(id || "");
  if (value.startsWith("control-refresh-")) {
    const parts = value.split("-");
    return `refresh-${parts.slice(-2).join("-")}`;
  }
  return short(value);
}
function timeLabel(value) {
  if (!value) return "";
  const date = new Date(String(value));
  if (Number.isNaN(date.getTime())) return String(value);
  return date.toLocaleString([], {month:"short", day:"numeric", hour:"numeric", minute:"2-digit"});
}
function timestampLine(label, value) {
  return value ? `<div class="subtle" title="${esc(value)}">${esc(label)} ${esc(timeLabel(value))}</div>` : "";
}
function channelLabel(tab) {
  const labels = {
    "Mission Control": "mission-control",
    "Control": "spartacus-control",
    "Runs": "runs",
    "Mouth": "mouth",
    "Artifacts": "artifacts",
    "Repo Maps": "repo-maps",
    "Specs": "specs",
    "Memory Proposals": "memory",
    "Workers": "agent-room",
    "Security": "security"
  };
  return labels[tab] || String(tab || "").toLowerCase().replaceAll(" ", "-");
}
function tabCount(tab) {
  if (!appState) return "";
  if (tab === "Runs") return (appState.runs || []).length;
  if (tab === "Mouth") return (appState.mouth || []).length + (appState.mouth_replies || []).length;
  if (tab === "Artifacts") return (appState.artifacts || []).length;
  if (tab === "Memory Proposals") return (appState.memory_proposals || []).length;
  if (tab === "Control") return (appState.control_nodes || []).filter(n => n.enabled).length;
  return "";
}
function mobileLabel(tab) {
  const labels = {
    "Mission Control": "Mission",
    "Memory Proposals": "Memory",
    "Repo Maps": "Maps"
  };
  return labels[tab] || tab;
}
function mobileIcon(tab) {
  const icons = {
    "Mission Control": "MC",
    "Control": "CT",
    "Runs": "RN",
    "Artifacts": "AR",
    "Mouth": "MO",
    "Repo Maps": "MP",
    "Specs": "SP",
    "Memory Proposals": "ME",
    "Workers": "AG",
    "Security": "SE"
  };
  return icons[tab] || tab.slice(0, 2).toUpperCase();
}
function resetInteractionForTab() {
  // A tab jump is an explicit navigation action, so any held detail/preview
  // state should yield to the current app state instead of staying locked.
  openRunId = null;
  interactionLock = false;
  if (pendingSig) { lastSig = pendingSig; pendingSig = null; }
}
function closeMobileMore() {
  const panel = document.getElementById("mobile-more-panel");
  const backdrop = document.getElementById("mobile-more-backdrop");
  if (panel) panel.hidden = true;
  if (backdrop) backdrop.hidden = true;
}
function toggleMobileMore() {
  const panel = document.getElementById("mobile-more-panel");
  const backdrop = document.getElementById("mobile-more-backdrop");
  if (!panel || !backdrop) return;
  const nextOpen = panel.hidden;
  panel.hidden = !nextOpen;
  backdrop.hidden = !nextOpen;
}
function selectTab(tab, scrollTop = false) {
  current = tab;
  resetInteractionForTab();
  closeMobileMore();
  render();
  updateSyncIndicator();
  if (scrollTop && window.matchMedia("(max-width: 820px)").matches) {
    window.scrollTo({top: 0, behavior: "smooth"});
  }
}
function initials(name) {
  const parts = String(name || "agent").split(/[\s/-]+/).filter(Boolean);
  return parts.slice(0, 2).map(part => part[0]).join("").toUpperCase() || "A";
}
function nodeStatusClass(n) {
  if (["online", "responding", "reachable"].includes(n.status)) return "success";
  if (["planned", "degraded"].includes(n.status)) return "blocked";
  return "failed";
}
function renderAgentList() {
  const nodes = appState ? (appState.control_nodes || []) : [];
  const workers = appState ? ((((appState.workers || {}).registry || {}).workers) || []) : [];
  const agentRows = [];
  for (const node of nodes) {
    agentRows.push({
      name: node.label,
      meta: node.reference ? "VPS proof target" : node.role,
      status: nodeStatusClass(node)
    });
  }
  for (const worker of workers.slice(0, 3)) {
    agentRows.push({
      name: worker.name || "worker",
      meta: worker.status || "registered",
      status: worker.adapter_pending ? "blocked" : "success"
    });
  }
  const rows = agentRows.slice(0, 8).map(agent => `<div class="agent-row">
    <div class="avatar">${esc(initials(agent.name))}</div>
    <div class="agent-copy">
      <div class="agent-name">${esc(agent.name)}</div>
      <div class="subtle">${esc(agent.meta)}</div>
    </div>
    <span class="status-dot ${esc(agent.status)}"></span>
  </div>`).join("");
  return rows || `<div class="agent-row"><div class="avatar">T</div><div class="agent-copy"><div class="agent-name">Theo</div><div class="subtle">loading</div></div><span class="status-dot blocked"></span></div>`;
}
function tabBar() {
  const nav = document.getElementById("tabs");
  nav.innerHTML = tabs.map(t => {
    const count = tabCount(t);
    const countHtml = count === "" || count === 0 ? "" : `<span class="tab-count">${esc(count)}</span>`;
    return `<button class="tab ${t === current ? "active" : ""}" data-tab="${esc(t)}"><span># ${esc(channelLabel(t))}</span>${countHtml}</button>`;
  }).join("");
  nav.querySelectorAll(".tab").forEach(btn => btn.onclick = () => selectTab(btn.dataset.tab));
  const agents = document.getElementById("agent-list");
  if (agents) agents.innerHTML = renderAgentList();
  renderMobileNav();
}
function renderMobileNav() {
  const nav = document.getElementById("mobile-bottom-nav");
  const grid = document.getElementById("mobile-more-grid");
  if (!nav || !grid) return;
  const primary = mobilePrimaryTabs.map(t => {
    const count = tabCount(t);
    const countHtml = count === "" || count === 0 ? "" : `<span class="tab-count">${esc(count)}</span>`;
    return `<button type="button" class="mobile-nav-button ${t === current ? "active" : ""}" data-mobile-tab="${esc(t)}">
      <span class="mobile-nav-icon">${esc(mobileIcon(t))}</span>
      <span>${esc(mobileLabel(t))}</span>
      ${countHtml}
    </button>`;
  }).join("");
  const moreActive = !mobilePrimaryTabs.includes(current);
  nav.innerHTML = `${primary}<button type="button" class="mobile-nav-button ${moreActive ? "active" : ""}" id="mobile-more-button">
    <span class="mobile-nav-icon">..</span>
    <span>More</span>
  </button>`;
  nav.querySelectorAll("[data-mobile-tab]").forEach(btn => btn.onclick = () => selectTab(btn.dataset.mobileTab, true));
  const moreButton = document.getElementById("mobile-more-button");
  if (moreButton) moreButton.onclick = toggleMobileMore;
  grid.innerHTML = tabs.filter(t => !mobilePrimaryTabs.includes(t)).map(t => {
    const count = tabCount(t);
    const countHtml = count === "" || count === 0 ? "" : `<span class="tab-count">${esc(count)}</span>`;
    return `<button type="button" class="tab ${t === current ? "active" : ""}" data-mobile-tab="${esc(t)}">
      <span># ${esc(channelLabel(t))}</span>${countHtml}
    </button>`;
  }).join("");
  grid.querySelectorAll("[data-mobile-tab]").forEach(btn => btn.onclick = () => selectTab(btn.dataset.mobileTab, true));
  const close = document.getElementById("mobile-more-close");
  const backdrop = document.getElementById("mobile-more-backdrop");
  if (close) close.onclick = closeMobileMore;
  if (backdrop) backdrop.onclick = closeMobileMore;
}
function applyChrome() {
  document.getElementById("stamp").textContent = `${appState.mode || "local"} · updated ${appState.generated_at}`;
  document.getElementById("mode-pill").textContent = appState.mode || "local";
  document.getElementById("operator-label").textContent = ((appState.admin || {}).user || "Operator");
  document.getElementById("channel-heading").textContent = channelLabel(current);
  const reference = (appState.control_nodes || []).find(n => n.reference) || {};
  const proof = document.getElementById("proof-summary");
  if (proof) {
    const latency = Number.isFinite(Number(reference.latency_ms)) ? ` · ${reference.latency_ms}ms` : "";
    proof.textContent = reference.status ? `Spartacus ${reference.status}${latency}` : "Spartacus proof loading";
  }
  const control = document.getElementById("control-link");
  const logout = document.getElementById("logout-btn");
  if ((appState.admin || {}).authenticated) {
    logout.classList.remove("hidden");
    logout.onclick = async () => {
      await fetch("/api/logout", {method: "POST"});
      window.location = "/login";
    };
  } else {
    logout.classList.add("hidden");
  }
  if (appState.control_ui_url) {
    control.href = appState.control_ui_url;
    control.classList.remove("hidden");
  } else {
    control.classList.add("hidden");
  }
}

function updateSyncIndicator() {
  const el = document.getElementById("sync-status");
  if (!el) return;
  if (connError) { el.textContent = "reconnecting…"; el.className = "subtle blocked"; return; }
  if (pendingSig) { el.textContent = "● new activity — Refresh"; el.className = "subtle"; return; }
  const ago = syncedAt ? Math.max(0, Math.round((Date.now() - syncedAt) / 1000)) : null;
  const when = ago === null ? "" : (ago < 1 ? "just now" : `${ago}s ago`);
  el.textContent = live ? `live · synced ${when}` : `paused · synced ${when}`;
  el.className = "subtle";
}

// force=true always re-renders and breaks any interaction lock (manual refresh).
async function loadState(force = false) {
  let data;
  try {
    const res = await fetch("/api/state", {cache: "no-store"});
    if (res.status === 401) { window.location = "/login"; return; }
    data = await res.json();
  } catch (err) {
    connError = true;
    updateSyncIndicator();
    return;
  }
  connError = false;
  appState = data;
  syncedAt = Date.now();
  applyChrome();
  const sig = stateSignature(appState);
  if (force) {
    pendingSig = null;
    lastSig = sig;
    render();
  } else if (sig !== lastSig) {
    // Real change. If the operator is mid-interaction, hold the render back and
    // surface a "new activity" affordance instead of clobbering their view.
    if (interactionLock) {
      pendingSig = sig;
    } else {
      lastSig = sig;
      render();
    }
  }
  updateSyncIndicator();
}

function syncTick() {
  if (live && document.visibilityState === "visible") {
    loadState(false);
  } else {
    updateSyncIndicator();
  }
}

function startPolling() {
  if (pollTimer) clearInterval(pollTimer);
  pollTimer = setInterval(syncTick, POLL_MS);
}

function manualRefresh() {
  interactionLock = false;
  openRunId = null;
  loadState(true);
}

function toggleLive() {
  live = !live;
  const btn = document.getElementById("live-btn");
  if (btn) btn.textContent = live ? "Pause" : "Resume";
  if (live) loadState(false);
  updateSyncIndicator();
}
function runCard(run) {
  const tests = run.tests || {};
  const git = run.git || {};
  return `<article class="card">
    <div class="row"><div class="title mono">${esc(short(run.job_id))}</div><span class="pill ${cls(run.status)}">${esc(run.status)}</span></div>
    <div class="subtle">${esc(run.lane)} / ${esc(run.worker)} / <span class="${esc(run.state)}">${esc(run.state)}</span></div>
    ${timestampLine("started", run.created_at)}
    ${timestampLine("finished", run.finished_at)}
    <p>${esc(run.summary)}</p>
    <div class="subtle">tests ${esc(tests.passed ?? 0)}/${esc(tests.failed ?? 0)} · branch ${esc(git.branch || "(none)")}</div>
    <p><button onclick="openRun('${esc(run.job_id)}')">Open Run</button></p>
  </article>`;
}
function closeRun() {
  openRunId = null;
  interactionLock = false;
  const pane = document.getElementById("run-detail");
  if (pane) pane.innerHTML = "";
  // Apply anything that arrived while the detail was open.
  if (pendingSig) { loadState(true); } else { updateSyncIndicator(); }
}
async function openRun(jobId) {
  // Lock auto-render so a poll cannot wipe the detail the operator is reading.
  openRunId = jobId;
  interactionLock = true;
  const res = await fetch(`/api/run/${encodeURIComponent(jobId)}`, {cache: "no-store"});
  const detail = await res.json();
  document.getElementById("run-detail").innerHTML = `<section class="card detail">
    <div class="row"><div class="title">Run ${esc(detail.job_id)}</div><span class="pill ${cls(detail.status)}">${esc(detail.status)}</span></div>
    <p><button onclick="closeRun()">Close</button></p>
    ${timestampLine("started", detail.created_at)}
    ${timestampLine("finished", detail.finished_at)}
    <p>${esc(detail.summary)}</p>
    <div class="split">
      <div><h3>Receipt</h3><pre>${esc(detail.receipt || "")}</pre></div>
      <div><h3>Result</h3><pre>${esc(JSON.stringify(detail.result || detail, null, 2))}</pre></div>
    </div>
    <h3>Transcript</h3><pre>${esc(detail.transcript_text || "(none)")}</pre>
  </section>`;
  document.getElementById("run-detail").scrollIntoView({block: "start"});
}
function renderRuns() {
  return `<div id="run-detail"></div><section class="grid">${(appState.runs || []).map(runCard).join("") || empty("No runs yet.")}</section>`;
}
async function previewArtifact(jobId, index, target) {
  // Opening a preview locks auto-render so the poll cannot wipe it.
  interactionLock = true;
  updateSyncIndicator();
  const res = await fetch(`/api/artifact?job_id=${encodeURIComponent(jobId)}&index=${index}`, {cache: "no-store"});
  const data = await res.json();
  if (data.blocked) {
    target.innerHTML = `<div class="blocked-box">blocked: ${esc(data.reason)}</div>`;
    return;
  }
  if (data.preview_kind === "html") {
    const iframe = document.createElement("iframe");
    iframe.setAttribute("sandbox", "");
    iframe.setAttribute("referrerpolicy", "no-referrer");
    iframe.srcdoc = `<meta http-equiv="Content-Security-Policy" content="default-src 'none'; img-src data:; style-src 'unsafe-inline';">` + data.content;
    target.innerHTML = "";
    target.appendChild(iframe);
    return;
  }
  if (data.preview_kind === "image") {
    target.innerHTML = `<img alt="" style="max-width:100%;border-radius:6px;border:1px solid var(--line)" src="${esc(data.data_url)}">`;
    return;
  }
  target.innerHTML = `<pre>${esc(data.content || "")}</pre>`;
}
function artifactCard(a) {
  const blocked = a.preview_kind === "html" && a.safe_to_render !== true;
  const artifactPath = String(a.path || "");
  const badPath = artifactPath.startsWith("/") || artifactPath.includes("../") || artifactPath.includes("..\\");
  const noPreview = a.preview_kind === "none";
  const blockReason = blocked ? "untrusted html" : badPath ? "unsafe path" : noPreview ? "no preview declared" : "";
  return `<article class="card">
    <div class="row"><div class="title">${esc(a.title || "Untitled")}</div><span class="pill">${esc(a.artifact_type)}</span></div>
    <div class="subtle">${esc(a.worker)} / ${esc(short(a.source_job))} / ${esc(a.preview_kind)}</div>
    ${timestampLine("run started", a.run_created_at)}
    <p>${esc(a.summary)}</p>
    <div class="mono subtle">${esc(a.path)}</div>
    ${blockReason ? `<div class="blocked-box">blocked: ${esc(blockReason)}</div>` : `<p><button onclick="previewArtifact('${esc(a.job_id)}', ${Number(a.index)}, this.parentElement.nextElementSibling)">Preview</button></p><div class="artifact-preview"></div>`}
  </article>`;
}
function renderArtifacts() {
  return `<section class="grid">${(appState.artifacts || []).map(artifactCard).join("") || empty("No artifacts yet.")}</section>`;
}
function renderMouth() {
  const commands = (appState.mouth || []).map(m => `<article class="card">
    <div class="row"><div class="title mono">${esc(short(m.command_id))}</div><span class="pill ${esc(m.state)}">${esc(m.state)}</span></div>
    <div class="subtle">${esc((m.source || {}).channel)} / ${esc((m.source || {}).sender_label)} / ${esc(m.mode)}</div>
    ${timestampLine("created", m.created_at)}
    <p>${esc(m.summary)}</p>
    <div class="mono subtle">job ${esc(short(m.job_id))}</div>
    ${m.result_path ? `<div class="mono subtle">result ${esc(m.result_path)}</div>` : ""}
    ${m.receipt_preview ? `<h3>Receipt</h3><pre>${esc(m.receipt_preview)}</pre>` : ""}
    <div class="subtle">${esc(m.record_path || "")}</div>
    <div class="blocked-box">Glass displays Mouth state only; dispatch still happens through bin/mouth + bin/dispatch.</div>
  </article>`).join("");
  const replies = (appState.mouth_replies || []).map(r => `<article class="card">
    <div class="row"><div class="title mono">reply ${esc(short(r.command_id))}</div><span class="pill ${r.ok ? "success" : "failed"}">${r.ok ? "ok" : "error"}</span></div>
    <div class="subtle">${esc(r.channel)} / target ${esc(r.target)} / exit ${esc(r.exit_code)}</div>
    ${timestampLine("created", r.created_at)}
    <div class="subtle">delivery ${(r.delivery || {}).status ? `<span class="pill success">${esc((r.delivery || {}).status)}</span> message ${esc((r.delivery || {}).message_id || "")}` : `<span class="pill blocked">pending</span>`}</div>
    ${timestampLine("delivered", (r.delivery || {}).created_at)}
    <pre>${esc(r.text || "")}</pre>
    ${r.result_path ? `<div class="mono subtle">result ${esc(r.result_path)}</div>` : ""}
    ${r.delivery_path ? `<div class="mono subtle">delivery ${esc(r.delivery_path)}</div>` : ""}
    <div class="subtle">${esc(r.record_path || "")}</div>
  </article>`).join("");
  return `<section class="stack">
    <div><h2 style="font-size:16px;margin:0 0 8px">Commands</h2><div class="grid">${commands || empty("No Mouth commands yet.")}</div></div>
    <div><h2 style="font-size:16px;margin:0 0 8px">Replies</h2><div class="grid">${replies || empty("No Mouth replies yet.")}</div></div>
  </section>`;
}
function focusRun() {
  const runs = appState.runs || [];
  return runs.find(run => ["partial", "blocked", "failed"].includes(run.status)) || runs[0] || null;
}
function runProgress(run) {
  if (!run) return 0;
  if (run.status === "success") return 100;
  if (run.status === "failed") return 100;
  if (run.status === "blocked") return 68;
  if (run.status === "partial") return 62;
  return 42;
}
function accentForStatus(status) {
  if (status === "success") return "accent-green";
  if (status === "failed") return "accent-red";
  if (status === "partial" || status === "blocked") return "accent-amber";
  return "accent-blue";
}
function latestControlReceipt() {
  const receipts = appState ? (appState.control_receipts || []) : [];
  return receipts[0] || null;
}
function eventTime(item) {
  const date = new Date(String(item.ts || ""));
  return Number.isNaN(date.getTime()) ? 0 : date.getTime();
}
function missionItems() {
  const items = [];
  const reference = (appState.control_nodes || []).find(n => n.reference);
  if (reference) {
    items.push({
      type: "node",
      ts: reference.checked_at || appState.generated_at,
      actor: reference.label || "Spartacus",
      title: "Spartacus gateway proof",
      body: reference.responding
        ? `Gateway answered at the app layer with HTTP ${reference.http_status || "ok"}.`
        : "Gateway proof is not fully responding yet.",
      status: reference.status || "unknown",
      meta: [`probe ${reference.probe || "tcp"}`, Number.isFinite(Number(reference.latency_ms)) ? `${reference.latency_ms}ms` : ""].filter(Boolean)
    });
  }
  for (const receipt of (appState.control_receipts || []).slice(0, 6)) {
    items.push({
      type: "control",
      ts: receipt.created_at || receipt.ts,
      actor: receipt.node_label || "Spartacus",
      title: receipt.title || "Control action receipt",
      body: receipt.summary || "",
      status: receipt.status || "review",
      meta: [
        receipt.state || "read_only",
        receipt.probe ? `probe ${receipt.probe}` : "",
        Number.isFinite(Number(receipt.latency_ms)) ? `${receipt.latency_ms}ms` : "",
        receipt.http_status ? `HTTP ${receipt.http_status}` : ""
      ].filter(Boolean)
    });
  }
  for (const run of (appState.runs || []).slice(0, 8)) {
    const tests = run.tests || {};
    items.push({
      type: "run",
      ts: run.finished_at || run.created_at,
      actor: run.worker || "Theo",
      title: run.summary || `Run ${short(run.job_id)}`,
      body: `Run ${short(run.job_id)} is ${run.status} / ${run.state}.`,
      status: run.status,
      run,
      meta: [`lane ${run.lane || "self"}`, `tests ${tests.passed ?? 0}/${tests.failed ?? 0}`]
    });
  }
  for (const command of (appState.mouth || []).slice(0, 5)) {
    items.push({
      type: "dispatch",
      ts: command.created_at,
      actor: ((command.source || {}).sender_label) || "Theo",
      title: command.summary || "Mouth command received",
      body: `Command ${short(command.command_id)} is ${command.state || "queued"}.`,
      status: command.state || "review",
      meta: [command.mode || "mouth", command.job_id ? `job ${short(command.job_id)}` : ""].filter(Boolean)
    });
  }
  for (const reply of (appState.mouth_replies || []).slice(0, 5)) {
    items.push({
      type: "receipt",
      ts: ((reply.delivery || {}).created_at) || reply.created_at,
      actor: "Theo",
      title: reply.ok ? "Receipt posted" : "Receipt blocked",
      body: reply.text || "",
      status: reply.ok ? "success" : "failed",
      meta: [reply.channel || "channel", (reply.delivery || {}).status || "pending"].filter(Boolean)
    });
  }
  return items.sort((a, b) => eventTime(b) - eventTime(a)).slice(0, 12);
}
function timelineItem(item) {
  const statusClass = item.type === "node" ? nodeStatusClass(item) : cls(item.status);
  const accent = item.type === "node" ? (item.status === "responding" ? "accent-green" : "accent-amber") : accentForStatus(item.status);
  const runButton = item.run ? `<button onclick="current='Runs'; render(); openRun('${esc(item.run.job_id)}')">View run</button>` : "";
  const progress = item.run ? `<div class="progress-track"><div class="progress-fill" style="width:${runProgress(item.run)}%"></div></div>` : "";
  return `<div class="timeline-row">
    <div class="timeline-time">${esc(timeLabel(item.ts) || "now")}</div>
    <div class="avatar">${esc(initials(item.actor))}</div>
    <article class="timeline-card ${accent}">
      <div class="row">
        <div>
          <div class="subtle">${esc(item.actor)} / ${esc(item.type)}</div>
          <div class="title">${esc(item.title)}</div>
        </div>
        <span class="pill ${statusClass}">${esc(item.status || "live")}</span>
      </div>
      <p class="muted">${esc(item.body)}</p>
      ${progress}
      <div class="timeline-meta">
        ${(item.meta || []).map(value => `<span class="pill">${esc(value)}</span>`).join("")}
        ${runButton}
      </div>
    </article>
  </div>`;
}
function composerBoundary(event) {
  event.preventDefault();
  const status = document.getElementById("composer-status");
  if (status) status.textContent = "Composer is staged only: dispatch still goes through bin/mouth + bin/dispatch with confirm and receipts.";
}
async function refreshSpartacusAction(button) {
  const status = document.getElementById("composer-status") || document.getElementById("control-action-status");
  const original = button ? button.textContent : "";
  if (button) {
    button.disabled = true;
    button.textContent = "Refreshing...";
  }
  if (status) status.textContent = "Refreshing Spartacus proof and writing a read-only receipt...";
  try {
    const res = await fetch("/api/control/spartacus/refresh", {
      method: "POST",
      headers: {"Content-Type": "application/json", "X-Theo-Glass": "1"},
      body: JSON.stringify({node_id: "spartacus"})
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `HTTP ${res.status}`);
    appState = data.state || appState;
    lastSig = stateSignature(appState);
    pendingSig = null;
    render();
    const freshStatus = document.getElementById("composer-status") || document.getElementById("control-action-status");
    if (freshStatus) freshStatus.textContent = `Receipt ${receiptLabel((data.receipt || {}).id)} recorded: ${(data.receipt || {}).status || "done"}.`;
  } catch (err) {
    if (status) status.textContent = `Refresh blocked: ${err.message || err}`;
  } finally {
    if (button) {
      button.disabled = false;
      button.textContent = original || "Refresh Spartacus";
    }
    updateSyncIndicator();
  }
}
function renderMission() {
  const reference = (appState.control_nodes || []).find(n => n.reference) || {};
  const run = focusRun();
  const tests = (run || {}).tests || {};
  const receipt = latestControlReceipt();
  const items = missionItems();
  const progress = run ? runProgress(run) : (reference.responding ? 100 : 50);
  return `<section>
    <article class="mission-hero">
      <div class="row">
        <div>
          <div class="subtle">Theo OS Mission Control</div>
          <div class="title" style="font-size:20px">Spartacus-first Agent OS cockpit</div>
        </div>
        <span class="pill ${nodeStatusClass(reference)}">${esc(reference.status || "loading")}</span>
      </div>
      <p class="muted">Live read model for dispatches, runs, receipts, approvals, artifacts, and the Spartacus VPS proof. The command composer is visible but intentionally inert until the receipt gate lands.</p>
      <div class="progress-track"><div class="progress-fill" style="width:${progress}%"></div></div>
      <div class="timeline-meta">
        <span class="pill success">admin gate</span>
        <span class="pill">gateway-owned auth</span>
        <span class="pill">${esc((appState.artifacts || []).length)} artifacts</span>
        <span class="pill">tests ${esc(tests.passed ?? 0)} / ${esc(tests.failed ?? 0)}</span>
        ${receipt ? `<span class="pill ${cls(receipt.status)}">last receipt ${esc(timeLabel(receipt.created_at))}</span>` : ""}
        <button type="button" onclick="refreshSpartacusAction(this)">Refresh Spartacus</button>
      </div>
    </article>
    <div class="timeline">${items.map(timelineItem).join("") || empty("No mission activity yet.")}</div>
    <form class="composer" onsubmit="composerBoundary(event)">
      <div class="composer-row">
        <button type="button" onclick="manualRefresh()">+</button>
        <input aria-label="Mission command composer" placeholder="Type /status, /receipt, /control, or mention an agent..." autocomplete="off">
        <button type="button" onclick="refreshSpartacusAction(this)">@Spartacus</button>
        <button type="submit">Stage</button>
      </div>
      <div class="composer-status" id="composer-status">Composer is read-only in this slice; no command is dispatched from Glass.</div>
    </form>
  </section>`;
}
function renderMissionRail() {
  if (!appState) return "";
  const reference = (appState.control_nodes || []).find(n => n.reference) || {};
  const run = focusRun();
  const tests = (run || {}).tests || {};
  const artifacts = (appState.artifacts || []).slice(0, 4);
  const controlReceipt = latestControlReceipt();
  const gateLabel = appState.writes_enabled ? "admin session" : "read-only gate";
  const receiptPreview = run ? `${run.summary || "Run receipt"}\nrun_id: ${run.job_id}\nstatus: ${run.status}\nstate: ${run.state}\nresult: ${run.result_path || ""}` : "No focused run yet.";
  const controlReceiptPreview = controlReceipt
    ? `${controlReceipt.title || "Spartacus receipt"}\nreceipt_id: ${controlReceipt.id}\nstatus: ${controlReceipt.status}\nstate: ${controlReceipt.state}\nprobe: ${controlReceipt.probe || "n/a"}\nlatency: ${Number.isFinite(Number(controlReceipt.latency_ms)) ? `${controlReceipt.latency_ms}ms` : "n/a"}\n${controlReceipt.summary || ""}`
    : "No Spartacus action receipt yet.";
  return `<div class="rail-header">
    <div>
      <div class="rail-title">Mission Details</div>
      <div class="subtle">${esc(run ? `Run ${short(run.job_id)}` : "Spartacus proof")}</div>
    </div>
    <span class="pill ${nodeStatusClass(reference)}">${esc(reference.status || "loading")}</span>
  </div>
  <section class="rail-section">
    <div class="rail-grid">
      <div class="metric"><div class="subtle">Run status</div><div class="metric-value">${esc(run ? run.status : "standby")}</div><div class="subtle">${esc(run ? run.state : "gateway proof")}</div></div>
      <div class="metric"><div class="subtle">Gate</div><div class="metric-value" style="font-size:16px">${esc(gateLabel)}</div><div class="subtle">no raw executor</div></div>
      <div class="metric"><div class="subtle">Tests</div><div class="metric-value">${esc(tests.passed ?? 0)} / ${esc(tests.failed ?? 0)}</div><div class="subtle">passed / failed</div></div>
      <div class="metric"><div class="subtle">Proof</div><div class="metric-value" style="font-size:16px">${esc(reference.probe || "tcp")}</div><div class="subtle">${Number.isFinite(Number(reference.latency_ms)) ? `${esc(reference.latency_ms)}ms` : "pending"}</div></div>
    </div>
  </section>
  <section class="rail-section">
    <div class="row"><div class="title">Artifacts</div><span class="pill">${esc(artifacts.length)}</span></div>
    <div class="stack" style="gap:8px;margin-top:10px">${artifacts.map(a => `<div class="row">
      <div><div class="title" style="font-size:13px">${esc(a.title || a.path || "artifact")}</div><div class="subtle">${esc(a.artifact_type || "file")} / ${esc(short(a.source_job))}</div></div>
      <button onclick="current='Artifacts'; render()">Open</button>
    </div>`).join("") || `<p class="muted">No artifacts yet.</p>`}</div>
  </section>
  <section class="rail-section">
    <div class="row"><div class="title">Receipt preview</div>${run ? `<button onclick="current='Runs'; render(); openRun('${esc(run.job_id)}')">Full receipt</button>` : ""}</div>
    <pre>${esc(receiptPreview)}</pre>
  </section>
  <section class="rail-section">
    <div class="row"><div class="title">Spartacus action receipt</div>${controlReceipt ? `<span class="pill ${cls(controlReceipt.status)}">${esc(controlReceipt.status)}</span>` : ""}</div>
    <pre>${esc(controlReceiptPreview)}</pre>
  </section>
  <section class="rail-section">
    <div class="title">Next action</div>
    <div class="stack" style="gap:8px;margin-top:10px">
      <a class="button" target="_blank" rel="noreferrer" href="${esc(reference.route || "/control/spartacus/")}">Open Spartacus Control</a>
      <button onclick="refreshSpartacusAction(this)">Refresh Spartacus status</button>
      <button onclick="current='Artifacts'; render()">Open artifacts</button>
    </div>
    <p class="subtle">Mutating actions wait for confirm + receipt gates; this panel observes and routes.</p>
  </section>`;
}
function proofRow(label, ok, detail) {
  return `<div class="row" style="align-items:flex-start;border-top:1px solid var(--line);padding:9px 0">
    <div>
      <div class="title" style="font-size:13px">${esc(label)}</div>
      <div class="subtle">${esc(detail)}</div>
    </div>
    <span class="pill ${ok ? "success" : "blocked"}">${ok ? "ready" : "blocked"}</span>
  </div>`;
}
function renderControl() {
  const nodes = appState.control_nodes || [];
  const reference = nodes.find(n => n.reference) || nodes[0] || {};
  const futureNodes = nodes.filter(n => !n.reference);
  const hasLatency = Number.isFinite(Number(reference.latency_ms));
  const checked = reference.checked_at ? `${timeLabel(reference.checked_at)}${hasLatency ? ` · ${reference.latency_ms}ms` : ""}` : "not checked yet";
  return `<section class="stack">
    <article class="card detail">
      <div class="row">
        <div>
          <div class="subtle">Jarvis / Agent OS Control Panel</div>
          <div class="title" style="font-size:20px">Spartacus VPS Proof</div>
        </div>
        <span class="pill ${nodeStatusClass(reference)}">${esc(reference.status || "unknown")}</span>
      </div>
      <p class="muted">Spartacus is the reference remote node: a VPS-backed OpenClaw gateway reachable from Glass through Railway. This proves the operator surface without a physical machine.</p>
      <div class="row" style="justify-content:flex-start;flex-wrap:wrap">
        <a class="button" target="_blank" rel="noreferrer" href="${esc(reference.route || "/control/spartacus/")}">Open Spartacus Control</a>
        <button onclick="refreshSpartacusAction(this)">Refresh Spartacus status</button>
        <a class="button" target="_blank" rel="noreferrer" href="/control/">Open Compatibility Route</a>
        <span class="pill success">admin-gated</span>
        <span class="pill">gateway-owned auth</span>
      </div>
      <div class="subtle" id="control-action-status" style="margin-top:8px">Refresh writes a local Glass receipt only; it does not mutate Spartacus.</div>
      <div class="mono subtle" style="margin-top:8px">Spartacus remote gateway configured</div>
      <div class="subtle">last gateway probe ${esc(checked)}${reference.http_status ? ` · HTTP ${esc(reference.http_status)}` : ""}${reference.probe ? ` · ${esc(reference.probe)}` : ""}</div>
      ${reference.error ? `<div class="blocked-box">probe failed: ${esc(reference.error)}</div>` : ""}
    </article>
    <article class="card detail">
      <div class="title">Proof Chain</div>
      ${proofRow("Glass admin door", (appState.admin || {}).authenticated || appState.mode === "local", "Single-operator login gates the Railway control surface before any upstream proxying.")}
      ${proofRow("Railway to Spartacus gateway", reference.reachable, `Socket probe from Glass web tier. ${hasLatency ? `${reference.latency_ms}ms observed.` : ""}`)}
      ${proofRow("Spartacus gateway response", reference.responding, reference.http_status ? `Gateway returned HTTP ${reference.http_status}; probe=${reference.probe || "http"}.` : "Port is reachable, but the gateway did not complete an app-layer response.")}
      ${proofRow("Control UI route", Boolean(reference.route), `${reference.route || "/control/spartacus/"} is the canonical operator entry; /control/ remains the old alias.`)}
      ${proofRow("Spartacus authority", true, "OpenClaw gateway token and device pairing stay on Spartacus; Glass stores no gateway token.")}
    </article>
    <div class="grid">${futureNodes.map(n => `<article class="card">
      <div class="row"><div class="title">${esc(n.label)}</div><span class="pill ${nodeStatusClass(n)}">${esc(n.status)}</span></div>
      <div class="subtle">${esc(n.role)}</div>
      <p>${esc(n.note)}</p>
      <div class="subtle">${esc(n.proof || "")}</div>
      ${n.target ? `<div class="mono subtle">${esc(n.target)}</div>` : ""}
      ${n.checked_at ? `<div class="subtle">checked ${esc(timeLabel(n.checked_at))}${n.latency_ms !== null ? ` · ${esc(n.latency_ms)}ms` : ""}</div>` : ""}
      ${n.error ? `<div class="blocked-box">probe failed: ${esc(n.error)}</div>` : ""}
      ${n.enabled ? `<p><a class="button" target="_blank" rel="noreferrer" href="${esc(n.route)}">Open ${esc(n.label)} Control</a></p>` : `<div class="blocked-box">Network path not configured yet.</div>`}
    </article>`).join("") || empty("No future Control nodes configured.")}</div>
    <article class="card detail">
      <div class="title">Operating Boundary</div>
      <p class="muted">This panel is the proof and entry surface. It does not execute shell commands, dispatch jobs, or accept arbitrary gateway URLs. Action buttons come next only behind confirm + receipt gates.</p>
      <div class="mono subtle">canonical /control/spartacus/ · compatibility /control/ -> Spartacus · no arbitrary gateway URLs</div>
    </article>
  </section>`;
}
function renderRepoMaps() {
  return `<section class="grid">${(appState.repo_maps || []).map(m => `<article class="card">
    <div class="row"><div class="title">${esc(m.lane)}</div><span class="pill ${m.fresh ? "success" : "blocked"}">${m.fresh ? "FRESH" : "STALE"}</span></div>
    <p class="mono">${esc(m.graph)}</p>
    <div class="subtle">recorded ${esc(short(m.recorded_head))} / current ${esc(short(m.current_head))}</div>
  </article>`).join("") || empty("No repo maps found.")}</section>`;
}
function renderSpecs() {
  return `<section class="stack">${(appState.specs || []).map(s => `<article class="card">
    <div class="row"><div class="title">${esc(s.path)}</div><span class="pill">${esc(s.kind)}</span></div>
    <div class="subtle">${esc(s.lane)}</div>
    <pre>${esc(s.text)}</pre>
  </article>`).join("") || empty("No specs found.")}</section>`;
}
async function queueProposal(item, verdict, btn) {
  const res = await fetch("/api/memory-proposal", {
    method: "POST",
    headers: {"Content-Type": "application/json", "X-Theo-Glass": "1"},
    body: JSON.stringify({...item, verdict})
  });
  const data = await res.json();
  btn.closest(".card").querySelector(".write-status").textContent = data.ok ? `queued ${verdict}` : `error: ${data.error}`;
}
function queueProposalById(id, verdict, btn) {
  const item = (appState.memory_proposals || []).find(p => p.id === id);
  if (!item) {
    btn.closest(".card").querySelector(".write-status").textContent = "error: proposal disappeared";
    return;
  }
  queueProposal(item, verdict, btn);
}
function renderProposals() {
  return `<section class="grid">${(appState.memory_proposals || []).map(p => `<article class="card">
    <div class="row"><div class="title">${esc(p.lane)}</div><span class="pill">${esc(short(p.source_job))}</span></div>
    <p>${esc(p.proposal)}</p>
    ${appState.writes_enabled ? `<p><button onclick="queueProposalById('${esc(p.id)}', 'approve', this)">Approve</button> <button class="danger" onclick="queueProposalById('${esc(p.id)}', 'reject', this)">Reject</button></p>` : `<div class="blocked-box">read-only Railway review: proposal verdict writes disabled</div>`}
    <div class="subtle write-status"></div>
  </article>`).join("") || empty("No memory proposals.")}</section>`;
}
function renderWorkers() {
  const operator = (appState.workers || {}).operator || {};
  const registry = ((appState.workers || {}).registry || {}).workers || [];
  return `<section class="grid">
    <article class="card">
      <div class="row"><div class="title">Operator (OpenClaw)</div><span class="pill ${operator.up ? "success" : "blocked"}">${operator.up ? "UP" : "DOWN"}</span></div>
      <p class="${operator.stale ? "blocked" : "success"}">${operator.stale ? "STALE" : "FRESH"}</p>
      <pre>${esc(JSON.stringify(operator, null, 2))}</pre>
      ${appState.control_ui_url ? `<a class="button" target="_blank" rel="noreferrer" href="${esc(appState.control_ui_url)}">Open Control UI</a>` : `<div class="blocked-box">Control UI is not exposed in Railway review mode.</div>`}
    </article>
    ${registry.map(w => `<article class="card">
      <div class="row"><div class="title">${esc(w.name)}</div><span class="pill ${w.adapter_pending ? "" : "success"}">${esc(w.status || "unknown")}</span></div>
      <p>${esc((w.strengths || []).join(", "))}</p>
      <pre>${esc(JSON.stringify(w, null, 2))}</pre>
    </article>`).join("")}
  </section>`;
}
async function updateCheck(item, checked, box) {
  const res = await fetch("/api/security-check", {
    method: "POST",
    headers: {"Content-Type": "application/json", "X-Theo-Glass": "1"},
    body: JSON.stringify({id: item.id, checked})
  });
  const data = await res.json();
  box.closest(".card").querySelector(".write-status").textContent = data.ok ? "updated" : `error: ${data.error}`;
}
function renderSecurity() {
  const items = ((appState.security || {}).items || []);
  return `<section class="grid">${items.map(item => `<article class="card">
    <label class="row"><span class="title">${esc(item.label)}</span><input type="checkbox" ${item.checked ? "checked" : ""} ${appState.writes_enabled ? "" : "disabled"} onchange='updateCheck(${JSON.stringify(item).replaceAll("'", "&#39;")}, this.checked, this)'></label>
    <p class="muted">${esc(item.description)}</p>
    <div class="subtle">updated ${esc(item.checked_at || item.ts || "never")}</div>
    ${appState.writes_enabled ? "" : `<div class="blocked-box">read-only Railway review: checklist writes disabled</div>`}
    <div class="subtle write-status"></div>
  </article>`).join("") || empty("No checklist configured.")}</section>`;
}
function empty(text) { return `<article class="card"><p>${esc(text)}</p></article>`; }
function render() {
  tabBar();
  if (!appState) return;
  const heading = document.getElementById("channel-heading");
  if (heading) heading.textContent = channelLabel(current);
  const renderers = {
    "Mission Control": renderMission,
    "Runs": renderRuns,
    "Mouth": renderMouth,
    "Control": renderControl,
    "Artifacts": renderArtifacts,
    "Repo Maps": renderRepoMaps,
    "Specs": renderSpecs,
    "Memory Proposals": renderProposals,
    "Workers": renderWorkers,
    "Security": renderSecurity
  };
  document.getElementById("app").innerHTML = renderers[current]();
  const rail = document.getElementById("detail-rail");
  if (rail) rail.innerHTML = renderMissionRail();
}
tabBar();
document.getElementById("refresh-btn").onclick = manualRefresh;
document.getElementById("live-btn").onclick = toggleLive;
// Pause polling while the tab is hidden; catch up immediately on return.
document.addEventListener("visibilitychange", () => {
  if (document.visibilityState === "visible" && live) loadState(false);
  updateSyncIndicator();
});
loadState(true);
startPolling();
// Cheap 1s tick so the "synced Xs ago" label counts up smoothly without
// hammering the server between polls.
setInterval(updateSyncIndicator, 1000);
</script>
</body>
</html>"""


class Handler(BaseHTTPRequestHandler):
    server_version = "TheoAgentOSGlass/0.5.8"

    def log_message(self, fmt: str, *args: object) -> None:
        sys.stderr.write("%s - %s\n" % (self.address_string(), fmt % args))

    def _headers(self, status: int, content_type: str, extra_headers: list[tuple[str, str]] | None = None) -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("X-Content-Type-Options", "nosniff")
        self.send_header("Referrer-Policy", "no-referrer")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Security-Policy", "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; frame-src 'self' about:; connect-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'")
        for key, value in extra_headers or []:
            self.send_header(key, value)
        self.end_headers()

    def send_json(self, data: object, status: int = 200, extra_headers: list[tuple[str, str]] | None = None) -> None:
        body = json.dumps(data, indent=2, sort_keys=True).encode("utf-8")
        self._headers(status, "application/json; charset=utf-8", extra_headers)
        try:
            self.wfile.write(body)
        except BrokenPipeError:
            # Browsers and smoke tests can close while a large refreshed state
            # is being returned. The action already completed; do not turn that
            # disconnect into a noisy server traceback.
            pass

    def send_html(self, body: str, status: int = 200, extra_headers: list[tuple[str, str]] | None = None) -> None:
        self._headers(status, "text/html; charset=utf-8", extra_headers)
        try:
            self.wfile.write(body.encode("utf-8"))
        except BrokenPipeError:
            pass

    def forbidden(self, reason: str = "forbidden") -> None:
        self.send_json({"ok": False, "error": reason}, 403)

    def check_host(self) -> bool:
        if local_host_header(self.headers.get("Host")):
            return True
        self.forbidden("bad host header; Glass is localhost-only")
        return False

    def admin_authenticated(self) -> bool:
        if not REMOTE_ADMIN:
            return False
        return verify_session(cookie_value(self.headers.get("Cookie"), ADMIN_COOKIE_NAME))

    def require_admin(self) -> bool:
        if not REMOTE_ADMIN:
            return True
        if self.admin_authenticated():
            return True
        self.send_json({"ok": False, "error": "admin login required", "auth_required": True}, 401)
        return False

    def login_client_key(self) -> str:
        # Railway normally supplies X-Forwarded-For; fall back to the socket
        # peer for local smoke tests and direct localhost runs.
        forwarded = (self.headers.get("X-Forwarded-For") or "").split(",", 1)[0].strip()
        if forwarded:
            return forwarded
        return str(self.client_address[0] if self.client_address else "unknown")

    def check_post(self) -> bool:
        if REMOTE_REVIEW:
            self.forbidden("Railway review mode is read-only")
            return False
        if not self.check_host():
            return False
        if REMOTE_ADMIN and not self.require_admin():
            return False
        if self.headers.get("X-Theo-Glass") != "1":
            self.forbidden("missing local Glass write header")
            return False
        if not same_origin(self.headers.get("Origin"), self.headers.get("Host")) or not same_origin(self.headers.get("Referer"), self.headers.get("Host")):
            self.forbidden("non-local origin rejected")
            return False
        return True

    def handle_login(self) -> None:
        if not REMOTE_ADMIN:
            self.send_json({"ok": False, "error": "admin mode is disabled"}, 404)
            return
        if not admin_configured():
            self.send_json({"ok": False, "error": "admin credentials are not configured"}, 503)
            return
        if not self.check_host():
            return
        if not same_origin(self.headers.get("Origin"), self.headers.get("Host")) or not same_origin(self.headers.get("Referer"), self.headers.get("Host")):
            self.forbidden("non-local origin rejected")
            return
        data = self.post_json()
        if data is None:
            return
        throttle_key = self.login_client_key()
        retry_after = login_throttle_retry_after(throttle_key)
        if retry_after:
            self.send_json(
                {"ok": False, "error": "too many failed login attempts", "retry_after_seconds": retry_after},
                429,
                [("Retry-After", str(retry_after))],
            )
            return
        user = data.get("user")
        password = data.get("password")
        if user != admin_user() or not isinstance(password, str) or not verify_password(password):
            record_login_failure(throttle_key)
            self.send_json({"ok": False, "error": "invalid login"}, 401)
            return
        clear_login_failures(throttle_key)
        headers = [("Set-Cookie", cookie_header(signed_session(admin_user()), max_age=admin_ttl_seconds()))]
        self.send_json({"ok": True, "user": admin_user()}, extra_headers=headers)

    def handle_logout(self) -> None:
        headers = [("Set-Cookie", cookie_header("", max_age=0))]
        self.send_json({"ok": True}, extra_headers=headers)

    def post_json(self) -> dict[str, object] | None:
        length = int(self.headers.get("Content-Length", "0") or "0")
        if length > 32_000:
            self.send_json({"ok": False, "error": "request too large"}, 413)
            return None
        try:
            return json.loads(self.rfile.read(length).decode("utf-8"))
        except Exception as exc:
            self.send_json({"ok": False, "error": f"invalid json: {exc}"}, 400)
            return None

    def handle_control_proxy(self) -> None:
        parsed = urlparse(self.path)
        route = resolve_control_proxy_route(parsed.path)
        if route is None:
            self.send_json({"ok": False, "error": "unknown control node"}, 404)
            return
        node_id, prefix = route

        if self.headers.get("Upgrade", "").lower() == "websocket":
            self.handle_control_websocket(node_id, prefix)
            return

        if parsed.path in {CONTROL_PROXY_PREFIX, f"{prefix}"} and not parsed.path.endswith("/"):
            self.send_response(302)
            location = f"{parsed.path}/"
            if parsed.query:
                location = f"{location}?{parsed.query}"
            self.send_header("Location", location)
            self.end_headers()
            return

        host, port = control_proxy_target(node_id)
        if not host:
            self.send_json({"ok": False, "error": f"control node {node_id} is not configured"}, 503)
            return
        upstream_path = control_upstream_path(self.path, prefix)
        connection = http.client.HTTPConnection(host, port, timeout=CONTROL_PROXY_TIMEOUT_SECONDS)

        try:
            connection.request(self.command, upstream_path, headers=proxy_request_headers(self.headers, node_id))
            response = connection.getresponse()
            body = response.read()
        except Exception as exc:
            self.send_json({"ok": False, "error": "control proxy failed", "detail": str(exc)}, 502)
            return
        finally:
            connection.close()

        self.send_response(response.status, response.reason)
        for key, value in proxy_response_headers(response.getheaders(), prefix):
            self.send_header(key, value)
        self.end_headers()
        if self.command != "HEAD":
            self.wfile.write(body)

    def handle_control_websocket(self, node_id: str, prefix: str) -> None:
        """Tunnel the Control UI WebSocket after Glass admin auth has passed."""
        host, port = control_proxy_target(node_id)
        if not host:
            self.send_json({"ok": False, "error": f"control node {node_id} is not configured"}, 503)
            return
        upstream_path = control_upstream_path(self.path, prefix)

        try:
            upstream = socket.create_connection((host, port), timeout=CONTROL_PROXY_TIMEOUT_SECONDS)
        except OSError as exc:
            self.send_json({"ok": False, "error": "control websocket proxy failed", "detail": str(exc)}, 502)
            return

        try:
            lines = [f"{self.command} {upstream_path} {self.request_version}", f"Host: {host}:{port}"]
            saw_connection = False
            saw_upgrade = False
            for key, value in self.headers.items():
                lower = key.lower()
                if lower in CONTROL_PROXY_PRIVATE_HEADERS or lower == "host" or lower == "proxy-connection":
                    continue
                if lower == "connection":
                    saw_connection = True
                    lines.append("Connection: Upgrade")
                    continue
                if lower == "upgrade":
                    saw_upgrade = True
                lines.append(f"{key}: {value}")
            if not saw_connection:
                lines.append("Connection: Upgrade")
            if not saw_upgrade:
                lines.append("Upgrade: websocket")
            upstream.sendall(("\r\n".join(lines) + "\r\n\r\n").encode("utf-8"))

            sockets = [self.connection, upstream]
            self.connection.setblocking(False)
            upstream.setblocking(False)
            self.close_connection = True

            while True:
                readable, _, exceptional = select.select(
                    sockets,
                    [],
                    sockets,
                    CONTROL_PROXY_TUNNEL_IDLE_SECONDS,
                )
                if exceptional or not readable:
                    break
                for source in readable:
                    try:
                        chunk = source.recv(65536)
                    except OSError:
                        return
                    if not chunk:
                        return
                    target_socket = upstream if source is self.connection else self.connection
                    target_socket.sendall(chunk)
        finally:
            upstream.close()

    def do_GET(self) -> None:
        if not self.check_host():
            return
        parsed = urlparse(self.path)
        if REMOTE_ADMIN and parsed.path == "/login":
            self.send_html(login_page("Invalid login." if "error=1" in parsed.query else ""))
            return
        if REMOTE_ADMIN and not self.admin_authenticated():
            if parsed.path == "/api/state":
                self.send_json({
                    "ok": False,
                    "auth_required": True,
                    "mode": glass_mode(),
                    "writes_enabled": False,
                    "admin": {"enabled": True, "authenticated": False, "user": admin_user()},
                }, 401)
                return
            if parsed.path.startswith("/api/"):
                self.send_json({"ok": False, "error": "admin login required", "auth_required": True}, 401)
                return
            self.send_html(login_page(), 401)
            return
        if is_control_proxy_path(parsed.path):
            self.handle_control_proxy()
            return
        if parsed.path in {"/", ""} or parsed.path.startswith("/run/"):
            self.send_html(page())
            return
        if parsed.path == "/api/state":
            self.send_json(state(self.admin_authenticated()))
            return
        if parsed.path.startswith("/api/run/"):
            job_id = parsed.path.rsplit("/", 1)[-1]
            detail = load_run(job_id)
            if not detail:
                self.send_json({"ok": False, "error": "run not found"}, 404)
                return
            self.send_json(detail)
            return
        if parsed.path == "/api/artifact":
            params = parse_qs(parsed.query)
            job_id = params.get("job_id", [""])[0]
            try:
                index = int(params.get("index", ["-1"])[0])
            except ValueError:
                index = -1
            artifact, path, reason = resolve_artifact(job_id, index)
            if not artifact or not path:
                self.send_json({"blocked": True, "reason": reason or "artifact blocked"})
                return
            preview_kind = str(artifact.get("preview_kind", "none"))
            safe = artifact.get("safe_to_render") is True
            if preview_kind == "html" and not safe:
                self.send_json({"blocked": True, "reason": "untrusted html"})
                return
            if preview_kind == "none":
                self.send_json({"blocked": True, "reason": "artifact declares no preview"})
                return
            raw = path.read_bytes()[:MAX_PREVIEW_BYTES]
            if preview_kind == "image":
                import base64
                suffix = path.suffix.lower()
                mime = "image/png" if suffix == ".png" else "image/jpeg" if suffix in {".jpg", ".jpeg"} else "image/gif" if suffix == ".gif" else "application/octet-stream"
                self.send_json({"blocked": False, "preview_kind": "image", "data_url": f"data:{mime};base64,{base64.b64encode(raw).decode('ascii')}"})
                return
            text = raw.decode("utf-8", errors="replace")
            self.send_json({"blocked": False, "preview_kind": preview_kind, "content": text})
            return
        self.send_json({"ok": False, "error": "not found"}, 404)

    def do_POST(self) -> None:
        parsed = urlparse(self.path)
        if REMOTE_ADMIN and parsed.path == "/api/login":
            self.handle_login()
            return
        if REMOTE_ADMIN and parsed.path == "/api/logout":
            self.handle_logout()
            return
        if not self.check_post():
            return
        data = self.post_json()
        if data is None:
            return
        if parsed.path == "/api/memory-proposal":
            verdict = data.get("verdict")
            proposal = data.get("proposal")
            source_job = data.get("source_job")
            if verdict not in {"approve", "reject"} or not isinstance(proposal, str) or not isinstance(source_job, str):
                self.send_json({"ok": False, "error": "invalid proposal verdict"}, 400)
                return
            known = {(item["source_job"], item["proposal"]) for item in memory_proposals(load_runs())}
            if (source_job, proposal) not in known:
                self.send_json({"ok": False, "error": "proposal is not declared by a result envelope"}, 400)
                return
            MEMORY_QUEUE.parent.mkdir(parents=True, exist_ok=True)
            entry = {
                "kind": "memory_verdict",
                "created_at": utc_now(),
                "ts": utc_now(),
                "lane": data.get("lane", "self"),
                "proposal": proposal,
                "proposal_id": data.get("id", f"{source_job}:unknown"),
                "source_job": source_job,
                "source_result": data.get("source_result", ""),
                "verdict": verdict,
                "status": "proposed",
            }
            with MEMORY_QUEUE.open("a", encoding="utf-8") as handle:
                handle.write(json.dumps(entry, sort_keys=True) + "\n")
            self.send_json({"ok": True, "entry": entry})
            return
        if parsed.path == "/api/security-check":
            item_id = data.get("id")
            if not isinstance(item_id, str):
                self.send_json({"ok": False, "error": "missing checklist id"}, 400)
                return
            checklist = security_checklist()
            items = checklist.get("items", []) if isinstance(checklist, dict) else []
            updated = False
            for item in items:
                if isinstance(item, dict) and item.get("id") == item_id:
                    item["checked"] = bool(data.get("checked"))
                    checked_at = utc_now()
                    item["checked_at"] = checked_at
                    item["ts"] = checked_at
                    updated = True
                    break
            if not updated:
                self.send_json({"ok": False, "error": "unknown checklist item"}, 404)
                return
            write_json(SECURITY_CHECKLIST, checklist)
            self.send_json({"ok": True})
            return
        if parsed.path == "/api/control/spartacus/refresh":
            node_id = data.get("node_id", "spartacus")
            if node_id != "spartacus":
                self.send_json({"ok": False, "error": "only Spartacus refresh is available"}, 400)
                return
            actor = admin_user() if REMOTE_ADMIN else "local-operator"
            try:
                receipt, node = refresh_control_node("spartacus", actor)
            except ValueError as exc:
                self.send_json({"ok": False, "error": str(exc)}, 400)
                return
            self.send_json({
                "ok": True,
                "receipt": receipt,
                "node": node,
                "state": state(self.admin_authenticated()),
            })
            return
        self.send_json({"ok": False, "error": "not found"}, 404)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run Theo Agent OS Glass.")
    parser.add_argument("--host", "--bind", dest="host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=4040)
    parser.add_argument("--remote-review", action="store_true", help="Allow non-local Host headers and disable writes for Railway-style public review.")
    parser.add_argument("--remote-admin", action="store_true", help="Allow non-local Host headers with single-operator admin login.")
    parser.add_argument("--hash-admin-password", action="store_true", help="Read an admin password from stdin and print THEO_GLASS_ADMIN_PASSWORD_HASH.")
    return parser.parse_args()


def main() -> int:
    global REMOTE_REVIEW, REMOTE_ADMIN
    args = parse_args()
    if args.hash_admin_password:
        password = sys.stdin.readline().rstrip("\n")
        if not password:
            print("password required on stdin", file=sys.stderr)
            return 2
        print(make_password_hash(password))
        return 0
    if args.remote_review and args.remote_admin:
        print("Choose --remote-review or --remote-admin, not both.", file=sys.stderr)
        return 2
    REMOTE_REVIEW = args.remote_review
    REMOTE_ADMIN = args.remote_admin
    if args.host != "127.0.0.1" and not (REMOTE_REVIEW or REMOTE_ADMIN):
        print("Glass refuses non-local bind values unless --remote-review or --remote-admin is set.", file=sys.stderr)
        return 2
    if REMOTE_ADMIN and not admin_configured():
        print("Glass remote-admin requires THEO_GLASS_ADMIN_SESSION_SECRET plus THEO_GLASS_ADMIN_PASSWORD_HASH or THEO_GLASS_ADMIN_PASSWORD.", file=sys.stderr)
        return 2
    if REMOTE_REVIEW and os.environ.get(REMOTE_REVIEW_ACK_ENV) != REMOTE_REVIEW_ACK_VALUE:
        exposure_errors = remote_review_exposure_errors()
        if exposure_errors:
            print("Glass remote-review refuses to expose non-demo run history.", file=sys.stderr)
            print(f"Set {REMOTE_REVIEW_ACK_ENV}={REMOTE_REVIEW_ACK_VALUE} only if public run exposure is intended.", file=sys.stderr)
            for error in exposure_errors:
                print(f"- {error}", file=sys.stderr)
            return 2
    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"Glass listening on http://{args.host}:{args.port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        return 0
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
