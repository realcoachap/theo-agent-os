</html>"""


def rel(path: Path) -> str:
    try:
        return str(path.resolve().relative_to(REPO_ROOT))
    except ValueError:
        return str(path)


def read_json(path: Path) -> object:
    return json.loads(path.read_text(encoding="utf-8"))


def write_json(path: Path, data: object) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    tmp.replace(path)


def run(cmd: list[str], cwd: Path | None = None, timeout: int = 5) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=timeout)


def local_host_header(value: str | None) -> bool:
    if REMOTE_REVIEW or REMOTE_ADMIN:
        return True
    if not value:
        return True
    host = value.rsplit("@", 1)[-1].split(":", 1)[0].strip("[]").lower()
    return host in LOCAL_HOSTS


def origin_matches_host(value: str | None, host_header: str | None) -> bool:
    if not value:
        return True
    parsed = urlparse(value)
    if parsed.scheme not in {"http", "https"}:
        return False
    origin_host = parsed.netloc.rsplit("@", 1)[-1].split(":", 1)[0].strip("[]").lower()
    request_host = (host_header or "").rsplit("@", 1)[-1].split(":", 1)[0].strip("[]").lower()
    return bool(origin_host and request_host and origin_host == request_host)


def same_origin(value: str | None, host_header: str | None = None) -> bool:
    if REMOTE_REVIEW:
        return True
    if REMOTE_ADMIN:
        return origin_matches_host(value, host_header)
    if not value:
        return True
    parsed = urlparse(value)
    return parsed.scheme in {"http", "https"} and local_host_header(parsed.netloc)


def path_inside(child: Path, parent: Path) -> bool:
    child_resolved = child.resolve()
    parent_resolved = parent.resolve()
    return child_resolved == parent_resolved or parent_resolved in child_resolved.parents


def validate_result(path: Path) -> list[str]:
    proc = run([str(REPO_ROOT / "bin" / "validate"), str(RESULT_SCHEMA), str(path)])
    if proc.returncode == 0:
        return []
    return [line.strip() for line in (proc.stderr or proc.stdout).splitlines() if line.strip()]


def index_entries() -> dict[str, dict[str, object]]:
    index = RUNS / "index.jsonl"
    entries: dict[str, dict[str, object]] = {}
    if not index.exists():
        return entries
    for line_no, line in enumerate(index.read_text(encoding="utf-8").splitlines(), start=1):
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        job_id = str(entry.get("job_id", f"index-line-{line_no}"))
        entries[job_id] = entry
    return entries


def result_paths() -> list[Path]:
    paths = {path.resolve() for path in RUNS.glob("*/*/result.json")}
    for entry in index_entries().values():
        run_dir = entry.get("run_dir")
        if isinstance(run_dir, str):
            candidate = (REPO_ROOT / run_dir / "result.json").resolve()
            if candidate.exists():
                paths.add(candidate)
    return sorted(paths, key=lambda path: path.stat().st_mtime, reverse=True)


def is_demo_run(result_path: Path, entry: dict[str, object] | None = None) -> bool:
    """Keep public Railway review from accidentally exposing real run history."""
    try:
        result = read_json(result_path)
    except Exception:
        return False
    if not isinstance(result, dict):
        return False
    run_dir = result_path.parent
    job: dict[str, object] = {}
    job_path = run_dir / "job.json"
    if job_path.exists():
        try:
            maybe_job = read_json(job_path)
            if isinstance(maybe_job, dict):
                job = maybe_job
        except Exception:
            job = {}
    worker = (entry or {}).get("worker") or job.get("worker") or artifact_worker(result)
    task = str(job.get("task", ""))
    summary = str(result.get("summary", ""))
    return worker == "demo" and task.startswith("DEMO Shot 2 Glass fixture:") and summary.startswith("DEMO ONLY:")


def remote_review_exposure_errors() -> list[str]:
    """Return non-demo run paths that would be public in --remote-review mode."""
    entries = index_entries()
    errors: list[str] = []
    for path in result_paths():
        try:
            result = read_json(path)
            job_id = str(result.get("job_id", path.parent.name)) if isinstance(result, dict) else path.parent.name
        except Exception:
            job_id = path.parent.name
        if not is_demo_run(path, entries.get(job_id)):
            errors.append(f"{rel(path)} is not a demo-only run")
    return errors


def load_runs() -> list[dict[str, object]]:
    entries = index_entries()
    loaded: list[dict[str, object]] = []
    for result_path in result_paths():
        run_dir = result_path.parent
        job_id = run_dir.name
        errors = validate_result(result_path)
        if errors:
            loaded.append({
                "valid": False,
                "job_id": job_id,
                "run_dir": rel(run_dir),
                "result_path": rel(result_path),
                "errors": errors,
                "summary": "Invalid result envelope.",
                "status": "failed",
                "state": "review",
                "worker": entries.get(job_id, {}).get("worker", "unknown"),
                "lane": entries.get(job_id, {}).get("lane", "unknown"),
                "artifacts": [],
                "memory_proposals": [],
            })
            continue
        result = read_json(result_path)
        entry = entries.get(str(result.get("job_id")), {})
        job_path = run_dir / "job.json"
        job: dict[str, object] = {}
        if job_path.exists():
            try:
                job = read_json(job_path)  # type: ignore[assignment]
            except Exception:
                job = {}
        loaded.append({
            "valid": True,
            "job_id": result.get("job_id", job_id),
            "run_dir": rel(run_dir),
            "result_path": rel(result_path),
            "status": result.get("status", "unknown"),
            "state": result.get("state", "unknown"),
            "summary": result.get("summary", ""),
            "tests": result.get("tests", {}),
            "git": result.get("git", {}),
            "worker": entry.get("worker") or job.get("worker") or artifact_worker(result),
            "lane": entry.get("lane") or job.get("lane") or "self",
            "created_at": entry.get("created_at", ""),
            "finished_at": entry.get("finished_at", ""),
            "artifacts": result.get("artifacts", []),
            "memory_proposals": result.get("memory_proposals", []),
            "transcript": result.get("transcript", ""),
            "result": result,
        })
    return loaded


def artifact_worker(result: object) -> str:
    if isinstance(result, dict):
        artifacts = result.get("artifacts", [])
        if isinstance(artifacts, list) and artifacts:
            first = artifacts[0]
            if isinstance(first, dict) and isinstance(first.get("worker"), str):
                return first["worker"]
    return "unknown"


def load_run(job_id: str) -> dict[str, object] | None:
    for item in load_runs():
        if item.get("job_id") == job_id:
            result_path = REPO_ROOT / str(item["result_path"])
            receipt = run([str(REPO_ROOT / "bin" / "receipt"), str(result_path)]).stdout
            transcript_text = ""
            result = item.get("result", {})
            if isinstance(result, dict):
                transcript_value = result.get("transcript")
                if isinstance(transcript_value, str):
                    transcript_path = (REPO_ROOT / transcript_value).resolve()
                    run_dir = (REPO_ROOT / str(item["run_dir"])).resolve()
                    if path_inside(transcript_path, run_dir) and transcript_path.exists():
                        transcript_text = transcript_path.read_text(encoding="utf-8", errors="replace")[:MAX_PREVIEW_BYTES]
            detail = dict(item)
            detail["receipt"] = receipt
            detail["transcript_text"] = transcript_text
            return detail
    return None


def lane_paths(runs: list[dict[str, object]]) -> list[Path]:
    paths = [REPO_ROOT]
    for item in runs:
        lane = item.get("lane")
        if not isinstance(lane, str) or lane == "self":
            continue
        candidate = Path(lane).expanduser().resolve()
        if candidate.exists() and candidate.is_dir() and candidate not in paths:
            paths.append(candidate)
    return paths


def repo_maps(runs: list[dict[str, object]]) -> list[dict[str, object]]:
    maps: list[dict[str, object]] = []
    for lane in lane_paths(runs):
        graph = lane / "graphify-out" / "graph.json"
        head_file = lane / "graphify-out" / ".head"
        if not graph.exists() and not head_file.exists():
            continue
        current = ""
        head_proc = run(["git", "rev-parse", "HEAD"], cwd=lane)
        if head_proc.returncode == 0:
            current = head_proc.stdout.strip()
        recorded = head_file.read_text(encoding="utf-8").strip() if head_file.exists() else ""
        maps.append({
            "lane": "self" if lane == REPO_ROOT else str(lane),
            "graph": rel(graph) if path_inside(graph, REPO_ROOT) else str(graph),
            "recorded_head": recorded,
            "current_head": current,
            "fresh": bool(current and recorded and current == recorded),
        })
    for item in runs:
        run_dir = REPO_ROOT / str(item.get("run_dir", ""))
        graph = run_dir / "graphify-out" / "graph.json"
        head_file = run_dir / "graphify-out" / ".head"
        if graph.exists() or head_file.exists():
            recorded = head_file.read_text(encoding="utf-8").strip() if head_file.exists() else ""
            maps.append({
                "lane": f"run:{item.get('job_id')}",
                "graph": rel(graph),
                "recorded_head": recorded,
                "current_head": recorded,
                "fresh": True,
            })
    return maps


def specs(runs: list[dict[str, object]]) -> list[dict[str, object]]:
    found: list[dict[str, object]] = []
    seen: set[Path] = set()
    for lane in lane_paths(runs):
        specs_root = lane / "specs"
        if not specs_root.exists():
            continue
        for spec in sorted(specs_root.glob("**/spec.md")):
            task = spec.parent / "tasks.md"
            for path, kind in ((spec, "spec"), (task, "tasks")):
                if not path.exists() or path.resolve() in seen:
                    continue
                seen.add(path.resolve())
                found.append({
                    "lane": "self" if lane == REPO_ROOT else str(lane),
                    "kind": kind,
                    "path": rel(path) if path_inside(path, REPO_ROOT) else str(path),
                    "text": path.read_text(encoding="utf-8", errors="replace")[:40_000],
                })
    return found


def artifact_list(runs: list[dict[str, object]]) -> list[dict[str, object]]:
    artifacts: list[dict[str, object]] = []
    for item in runs:
        for index, artifact in enumerate(item.get("artifacts", [])):
            if not isinstance(artifact, dict):
                continue
            row = dict(artifact)
            row["job_id"] = item.get("job_id")
            row["run_dir"] = item.get("run_dir")
            row["index"] = index
            artifacts.append(row)
    return artifacts


def memory_proposals(runs: list[dict[str, object]]) -> list[dict[str, object]]:
    proposals: list[dict[str, object]] = []
    for item in runs:
        lane = item.get("lane", "self")
        for index, proposal in enumerate(item.get("memory_proposals", [])):
            proposals.append({
                "id": f"{item.get('job_id')}:{index}",
                "source_job": item.get("job_id"),
                "source_result": item.get("result_path"),
                "lane": lane,
                "proposal": str(proposal),
            })
    return proposals


def security_checklist() -> dict[str, object]:
    if SECURITY_CHECKLIST.exists():
        return read_json(SECURITY_CHECKLIST)  # type: ignore[return-value]
    return {"version": "0.1.0", "items": []}


def operator_status() -> dict[str, object]:
    path = RUNS / "operator-status.json"
    pinned = PINNED_VERSION.read_text(encoding="utf-8").strip() if PINNED_VERSION.exists() else ""
    if not path.exists():
        return {"stale": True, "up": False, "pinned": pinned, "summary": "operator-status.json missing"}
    try:
        data = read_json(path)
    except Exception as exc:
        return {"stale": True, "up": False, "pinned": pinned, "summary": f"operator-status unreadable: {exc}"}
    ts = str(data.get("ts", ""))
    stale = True
    try:
        parsed = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        stale = time.time() - parsed.timestamp() > 600
    except Exception:
        stale = True
    if isinstance(data, dict):
        data = dict(data)
        data["stale"] = stale
        return data
    return {"stale": True, "up": False, "pinned": pinned, "summary": "operator-status invalid"}


def workers() -> dict[str, object]:
    registry = read_json(REGISTRY) if REGISTRY.exists() else {"workers": []}
    return {"registry": registry, "operator": operator_status()}


def mouth_commands() -> list[dict[str, object]]:
    records: list[dict[str, object]] = []
    if not MOUTH_INBOX.exists():
        return records
    for path in sorted(MOUTH_INBOX.glob("*/mouth.json"), key=lambda item: item.stat().st_mtime, reverse=True):
        try:
            data = read_json(path)
        except Exception:
            continue
        if isinstance(data, dict):
            row = dict(data)
            row["record_path"] = rel(path)
            records.append(row)
    return records


def mouth_replies() -> list[dict[str, object]]:
    records: list[dict[str, object]] = []
    if not MOUTH_OUTBOX.exists():
        return records
    for path in sorted(MOUTH_OUTBOX.glob("*/reply.json"), key=lambda item: item.stat().st_mtime, reverse=True):
        try:
            data = read_json(path)
        except Exception:
            continue
        if isinstance(data, dict):
            row = dict(data)
            row["record_path"] = rel(path)
            sent_path = path.parent / "sent.json"
            if sent_path.exists():
                try:
                    sent = read_json(sent_path)
                except Exception:
                    sent = {}
                if isinstance(sent, dict):
                    row["delivery"] = sent
                    row["delivery_path"] = rel(sent_path)
            records.append(row)
    return records


def state(authenticated: bool = False) -> dict[str, object]:
    runs = load_runs()
    return {
        "generated_at": utc_now(),
        "mode": glass_mode(),
        "writes_enabled": writes_enabled(authenticated),
        "admin": {
            "enabled": REMOTE_ADMIN,
            "authenticated": authenticated,
            "user": admin_user() if REMOTE_ADMIN else "",
        },
        "runs": runs,
        "artifacts": artifact_list(runs),
        "repo_maps": repo_maps(runs),
        "specs": specs(runs),
        "memory_proposals": memory_proposals(runs),
        "mouth": mouth_commands(),
        "mouth_replies": mouth_replies(),
        "workers": workers(),
        "security": security_checklist(),
        "control_ui_url": "" if (REMOTE_REVIEW or REMOTE_ADMIN) else "http://127.0.0.1:18789",
    }


def resolve_artifact(job_id: str, index: int) -> tuple[dict[str, object] | None, Path | None, str]:
    item = load_run(job_id)
    if not item or not item.get("valid"):
        return None, None, "run not found"
    artifacts = item.get("artifacts", [])
    if not isinstance(artifacts, list) or index < 0 or index >= len(artifacts):
        return None, None, "artifact not found"
    artifact = artifacts[index]
    if not isinstance(artifact, dict):
        return None, None, "artifact invalid"
    raw = artifact.get("path")
    if not isinstance(raw, str) or not raw:
        return artifact, None, "artifact path missing"
    raw_path = Path(raw)
    if raw_path.is_absolute():
        return artifact, None, "absolute artifact paths are blocked"
    run_dir = (REPO_ROOT / str(item["run_dir"])).resolve()
    candidates = [(REPO_ROOT / raw_path).resolve(), (run_dir / raw_path).resolve()]
    path = next((candidate for candidate in candidates if candidate.exists()), candidates[0])
    if not path_inside(path, run_dir):
        return artifact, None, "artifact path escapes its run directory"
    if not path.exists() or not path.is_file():
        return artifact, None, "artifact file missing"
    return artifact, path, ""


