#!/usr/bin/env python3
"""Theo Agent OS Glass v0.4.4 - Noted by Theo - 2026-06-10.

Localhost-only Mission Control for Shot 2. Glass reads Foundry run envelopes
and exposes only two tiny write lanes: memory proposal verdict queue entries
and manual security checklist attestations.

Railway review mode is intentionally read-only. It exists so Coach and Fable
can inspect Shot 2 through a stable URL without exposing local operator writes.
"""

from __future__ import annotations

import argparse
import base64
import hashlib
import hmac
import json
import os
import secrets
import subprocess
import sys
import time
from datetime import datetime, timezone
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse


REPO_ROOT = Path(__file__).resolve().parents[1]
RUNS = REPO_ROOT / "runs"
MOUTH_INBOX = REPO_ROOT / "jobs" / "inbox"
MOUTH_OUTBOX = REPO_ROOT / "jobs" / "outbox"
MEMORY_QUEUE = REPO_ROOT / "memory" / "queue.jsonl"
SECURITY_CHECKLIST = REPO_ROOT / "security" / "checklist.json"
REGISTRY = REPO_ROOT / "registry" / "workers.json"
PINNED_VERSION = REPO_ROOT / "registry" / "pinned-version.txt"
RESULT_SCHEMA = REPO_ROOT / "schemas" / "result.schema.json"
LOCAL_HOSTS = {"127.0.0.1", "localhost"}
MAX_PREVIEW_BYTES = 120_000
REMOTE_REVIEW = False
REMOTE_ADMIN = False
REMOTE_REVIEW_ACK_ENV = "THEO_GLASS_REMOTE_REVIEW_ACK"
REMOTE_REVIEW_ACK_VALUE = "public-runs-ok"
ADMIN_COOKIE_NAME = "theo_glass_admin"
ADMIN_USER_ENV = "THEO_GLASS_ADMIN_USER"
ADMIN_PASSWORD_ENV = "THEO_GLASS_ADMIN_PASSWORD"
ADMIN_PASSWORD_HASH_ENV = "THEO_GLASS_ADMIN_PASSWORD_HASH"
ADMIN_SESSION_SECRET_ENV = "THEO_GLASS_ADMIN_SESSION_SECRET"
ADMIN_TTL_ENV = "THEO_GLASS_ADMIN_TTL_SECONDS"
ADMIN_LOGIN_MAX_FAILURES_ENV = "THEO_GLASS_ADMIN_LOGIN_MAX_FAILURES"
ADMIN_LOGIN_WINDOW_ENV = "THEO_GLASS_ADMIN_LOGIN_WINDOW_SECONDS"
DEFAULT_ADMIN_TTL_SECONDS = 8 * 60 * 60
DEFAULT_ADMIN_LOGIN_MAX_FAILURES = 5
DEFAULT_ADMIN_LOGIN_WINDOW_SECONDS = 5 * 60
ADMIN_LOGIN_FAILURES: dict[str, list[float]] = {}


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def glass_mode() -> str:
    if REMOTE_ADMIN:
        return "railway-admin"
    if REMOTE_REVIEW:
        return "railway-review"
    return "local"


def writes_enabled(authenticated: bool = False) -> bool:
    if REMOTE_REVIEW:
        return False
    if REMOTE_ADMIN:
        return authenticated
    return True


def admin_user() -> str:
    return os.environ.get(ADMIN_USER_ENV, "coach")


def admin_ttl_seconds() -> int:
    try:
        return max(300, min(int(os.environ.get(ADMIN_TTL_ENV, str(DEFAULT_ADMIN_TTL_SECONDS))), 7 * 24 * 60 * 60))
    except ValueError:
        return DEFAULT_ADMIN_TTL_SECONDS


def bounded_int_env(name: str, default: int, minimum: int, maximum: int) -> int:
    try:
        return max(minimum, min(int(os.environ.get(name, str(default))), maximum))
    except ValueError:
        return default


def admin_login_max_failures() -> int:
    return bounded_int_env(ADMIN_LOGIN_MAX_FAILURES_ENV, DEFAULT_ADMIN_LOGIN_MAX_FAILURES, 1, 100)


def admin_login_window_seconds() -> int:
    return bounded_int_env(ADMIN_LOGIN_WINDOW_ENV, DEFAULT_ADMIN_LOGIN_WINDOW_SECONDS, 30, 60 * 60)


def prune_login_failures(key: str, now: float | None = None) -> list[float]:
    now = now if now is not None else time.time()
    window = admin_login_window_seconds()
    failures = [stamp for stamp in ADMIN_LOGIN_FAILURES.get(key, []) if now - stamp < window]
    if failures:
        ADMIN_LOGIN_FAILURES[key] = failures
    else:
        ADMIN_LOGIN_FAILURES.pop(key, None)
    return failures


def login_throttle_retry_after(key: str) -> int:
    failures = prune_login_failures(key)
    if len(failures) < admin_login_max_failures():
        return 0
    return max(1, int(admin_login_window_seconds() - (time.time() - failures[0])))


def record_login_failure(key: str) -> None:
    failures = prune_login_failures(key)
    failures.append(time.time())
    ADMIN_LOGIN_FAILURES[key] = failures


def clear_login_failures(key: str) -> None:
    ADMIN_LOGIN_FAILURES.pop(key, None)


def admin_configured() -> bool:
    return bool(
        os.environ.get(ADMIN_SESSION_SECRET_ENV)
        and (os.environ.get(ADMIN_PASSWORD_HASH_ENV) or os.environ.get(ADMIN_PASSWORD_ENV))
    )


def make_password_hash(password: str, salt: str | None = None, iterations: int = 210_000) -> str:
    salt = salt or secrets.token_hex(16)
    digest = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), salt.encode("utf-8"), iterations)
    encoded = base64.urlsafe_b64encode(digest).decode("ascii").rstrip("=")
    return f"pbkdf2_sha256${iterations}${salt}${encoded}"


def verify_password(password: str) -> bool:
    configured_hash = os.environ.get(ADMIN_PASSWORD_HASH_ENV, "")
    if configured_hash:
        try:
            algorithm, iterations_text, salt, expected = configured_hash.split("$", 3)
            if algorithm != "pbkdf2_sha256":
                return False
            actual = make_password_hash(password, salt=salt, iterations=int(iterations_text)).rsplit("$", 1)[-1]
            return hmac.compare_digest(actual, expected)
        except Exception:
            return False
    configured_password = os.environ.get(ADMIN_PASSWORD_ENV, "")
    return bool(configured_password) and hmac.compare_digest(password, configured_password)


def b64url(data: bytes) -> str:
    return base64.urlsafe_b64encode(data).decode("ascii").rstrip("=")


def b64url_decode(data: str) -> bytes:
    return base64.urlsafe_b64decode(data + "=" * (-len(data) % 4))


def signed_session(user: str) -> str:
    now = int(time.time())
    payload = b64url(json.dumps({"u": user, "iat": now, "exp": now + admin_ttl_seconds()}, separators=(",", ":")).encode("utf-8"))
    signature = hmac.new(os.environ[ADMIN_SESSION_SECRET_ENV].encode("utf-8"), payload.encode("ascii"), hashlib.sha256).digest()
    return f"{payload}.{b64url(signature)}"


def verify_session(cookie_value: str) -> bool:
    if not cookie_value or not os.environ.get(ADMIN_SESSION_SECRET_ENV):
        return False
    try:
        payload, signature = cookie_value.split(".", 1)
        expected = hmac.new(os.environ[ADMIN_SESSION_SECRET_ENV].encode("utf-8"), payload.encode("ascii"), hashlib.sha256).digest()
        if not hmac.compare_digest(b64url(expected), signature):
            return False
        data = json.loads(b64url_decode(payload).decode("utf-8"))
        return data.get("u") == admin_user() and int(data.get("exp", 0)) >= int(time.time())
    except Exception:
        return False


def cookie_value(header: str | None, name: str) -> str:
    if not header:
        return ""
    for part in header.split(";"):
        if "=" not in part:
            continue
        key, value = part.split("=", 1)
        if key.strip() == name:
            return value.strip()
    return ""


def cookie_header(value: str, max_age: int | None = None) -> str:
    pieces = [f"{ADMIN_COOKIE_NAME}={value}", "Path=/", "HttpOnly", "SameSite=Lax"]
    if REMOTE_ADMIN:
        pieces.append("Secure")
    if max_age is not None:
        pieces.append(f"Max-Age={max_age}")
    return "; ".join(pieces)


def login_page(error: str = "") -> str:
    error_html = f'<div class="error">{error}</div>' if error else ""
    return f"""<!doctype html>
<html lang="en">
<head>
