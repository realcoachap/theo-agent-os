def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def file_mtime_utc(path: Path) -> str:
    """Fallback timestamp for legacy records that predate explicit envelope times."""
    return datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).isoformat(timespec="seconds")


def glass_mode() -> str:
    if REMOTE_ADMIN:
        return "railway-admin"
    if REMOTE_REVIEW:
        return "railway-review"
    return "local"


def writes_enabled(authenticated: bool = False) -> bool:
    if REMOTE_REVIEW:
        return False
    if REMOTE_ADMIN:
        return authenticated
    return True


def admin_user() -> str:
    return os.environ.get(ADMIN_USER_ENV, "coach")


def admin_ttl_seconds() -> int:
    try:
        return max(300, min(int(os.environ.get(ADMIN_TTL_ENV, str(DEFAULT_ADMIN_TTL_SECONDS))), 7 * 24 * 60 * 60))
    except ValueError:
        return DEFAULT_ADMIN_TTL_SECONDS


def bounded_int_env(name: str, default: int, minimum: int, maximum: int) -> int:
    try:
        return max(minimum, min(int(os.environ.get(name, str(default))), maximum))
    except ValueError:
        return default


def admin_login_max_failures() -> int:
    return bounded_int_env(ADMIN_LOGIN_MAX_FAILURES_ENV, DEFAULT_ADMIN_LOGIN_MAX_FAILURES, 1, 100)


def admin_login_window_seconds() -> int:
    return bounded_int_env(ADMIN_LOGIN_WINDOW_ENV, DEFAULT_ADMIN_LOGIN_WINDOW_SECONDS, 30, 60 * 60)


def prune_login_failures(key: str, now: float | None = None) -> list[float]:
    now = now if now is not None else time.time()
    window = admin_login_window_seconds()
    failures = [stamp for stamp in ADMIN_LOGIN_FAILURES.get(key, []) if now - stamp < window]
    if failures:
        ADMIN_LOGIN_FAILURES[key] = failures
    else:
        ADMIN_LOGIN_FAILURES.pop(key, None)
    return failures


def login_throttle_retry_after(key: str) -> int:
    failures = prune_login_failures(key)
    if len(failures) < admin_login_max_failures():
        return 0
    return max(1, int(admin_login_window_seconds() - (time.time() - failures[0])))


def record_login_failure(key: str) -> None:
    failures = prune_login_failures(key)
    failures.append(time.time())
    ADMIN_LOGIN_FAILURES[key] = failures


def clear_login_failures(key: str) -> None:
    ADMIN_LOGIN_FAILURES.pop(key, None)


def admin_configured() -> bool:
    return bool(
        os.environ.get(ADMIN_SESSION_SECRET_ENV)
        and (os.environ.get(ADMIN_PASSWORD_HASH_ENV) or os.environ.get(ADMIN_PASSWORD_ENV))
    )


def make_password_hash(password: str, salt: str | None = None, iterations: int = 210_000) -> str:
    salt = salt or secrets.token_hex(16)
    digest = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), salt.encode("utf-8"), iterations)
    encoded = base64.urlsafe_b64encode(digest).decode("ascii").rstrip("=")
    return f"pbkdf2_sha256${iterations}${salt}${encoded}"


def verify_password(password: str) -> bool:
    configured_hash = os.environ.get(ADMIN_PASSWORD_HASH_ENV, "")
    if configured_hash:
        try:
            algorithm, iterations_text, salt, expected = configured_hash.split("$", 3)
            if algorithm != "pbkdf2_sha256":
                return False
            actual = make_password_hash(password, salt=salt, iterations=int(iterations_text)).rsplit("$", 1)[-1]
            return hmac.compare_digest(actual, expected)
        except Exception:
            return False
    configured_password = os.environ.get(ADMIN_PASSWORD_ENV, "")
    return bool(configured_password) and hmac.compare_digest(password, configured_password)


def b64url(data: bytes) -> str:
    return base64.urlsafe_b64encode(data).decode("ascii").rstrip("=")


def b64url_decode(data: str) -> bytes:
    return base64.urlsafe_b64decode(data + "=" * (-len(data) % 4))


def signed_session(user: str) -> str:
    now = int(time.time())
    payload = b64url(json.dumps({"u": user, "iat": now, "exp": now + admin_ttl_seconds()}, separators=(",", ":")).encode("utf-8"))
    signature = hmac.new(os.environ[ADMIN_SESSION_SECRET_ENV].encode("utf-8"), payload.encode("ascii"), hashlib.sha256).digest()
    return f"{payload}.{b64url(signature)}"


def verify_session(cookie_value: str) -> bool:
    if not cookie_value or not os.environ.get(ADMIN_SESSION_SECRET_ENV):
        return False
    try:
        payload, signature = cookie_value.split(".", 1)
        expected = hmac.new(os.environ[ADMIN_SESSION_SECRET_ENV].encode("utf-8"), payload.encode("ascii"), hashlib.sha256).digest()
        if not hmac.compare_digest(b64url(expected), signature):
            return False
        data = json.loads(b64url_decode(payload).decode("utf-8"))
        return data.get("u") == admin_user() and int(data.get("exp", 0)) >= int(time.time())
    except Exception:
        return False


def cookie_value(header: str | None, name: str) -> str:
    if not header:
        return ""
    for part in header.split(";"):
        if "=" not in part:
            continue
        key, value = part.split("=", 1)
        if key.strip() == name:
            return value.strip()
    return ""


def cookie_header(value: str, max_age: int | None = None) -> str:
    pieces = [f"{ADMIN_COOKIE_NAME}={value}", "Path=/", "HttpOnly", "SameSite=Lax"]
    if REMOTE_ADMIN:
        pieces.append("Secure")
    if max_age is not None:
        pieces.append(f"Max-Age={max_age}")
    return "; ".join(pieces)


def control_node_env_name(node_id: str, suffix: str) -> str:
    return f"THEO_GLASS_CONTROL_{node_id.upper()}_{suffix}"


def control_node_target(node_id: str) -> tuple[str, int]:
    """Resolve a known gateway target without storing OpenClaw tokens in Glass."""
    definition = CONTROL_NODE_DEFINITIONS[node_id]
    host = os.environ.get(control_node_env_name(node_id, "HOST"), "").strip()
    if not host and definition.get("legacy_env"):
        host = os.environ.get(CONTROL_PROXY_TARGET_HOST_ENV, "").strip()
    if not host:
        host = str(definition["default_host"]).strip()

    port_text = os.environ.get(control_node_env_name(node_id, "PORT"), "").strip()
    if not port_text and definition.get("legacy_env"):
        port_text = os.environ.get(CONTROL_PROXY_TARGET_PORT_ENV, "").strip()
    if not port_text:
        port_text = str(definition["default_port"])
    try:
        port = int(port_text)
    except ValueError:
        port = int(definition["default_port"])
    return host, port


def control_node_health(node_id: str, host: str, port: int, *, force: bool = False) -> dict[str, object]:
    """Small cached proof that Railway can reach and hear a gateway."""
    if not host:
        return {"status": "planned", "reachable": False, "responding": False, "checked_at": "", "latency_ms": None}
    cache_key = f"{node_id}:{host}:{port}"
    now = time.monotonic()
    cached = CONTROL_NODE_HEALTH_CACHE.get(cache_key)
    if cached and not force and now - cached[0] < CONTROL_NODE_PROBE_TTL_SECONDS:
        return dict(cached[1])

    started = time.monotonic()
    checked_at = utc_now()
    try:
        with socket.create_connection((host, port), timeout=CONTROL_NODE_PROBE_TIMEOUT_SECONDS):
            pass
    except OSError as exc:
        health = {
            "status": "unreachable",
            "reachable": False,
            "responding": False,
            "checked_at": checked_at,
            "latency_ms": None,
            "error": type(exc).__name__,
        }
        CONTROL_NODE_HEALTH_CACHE[cache_key] = (now, health)
        return dict(health)

    latency_ms = int((time.monotonic() - started) * 1000)
    health = {
        "status": "reachable",
        "reachable": True,
        "responding": False,
        "checked_at": checked_at,
        "latency_ms": latency_ms,
        "http_status": None,
        "probe": "tcp",
    }
    connection = http.client.HTTPConnection(host, port, timeout=CONTROL_NODE_PROBE_TIMEOUT_SECONDS)
    try:
        connection.request("GET", "/", headers={"Host": f"{host}:{port}"})
        response = connection.getresponse()
        body = response.read(4096)
        app_marker = b"OpenClaw" in body or b"Control" in body or b"openclaw" in body.lower()
        if response.status < 500:
            health.update({
                "status": "responding",
                "responding": True,
                "http_status": response.status,
                "probe": "control-ui" if app_marker else "http",
            })
        else:
            health.update({"status": "degraded", "http_status": response.status, "error": f"http_{response.status}"})
    except Exception as exc:
        health.update({"status": "degraded", "error": type(exc).__name__})
    finally:
        connection.close()
    CONTROL_NODE_HEALTH_CACHE[cache_key] = (now, health)
    return dict(health)


def control_node_row(node_id: str, definition: dict[str, object], host: str, port: int, health: dict[str, object]) -> dict[str, object]:
    return {
        "id": node_id,
        "label": definition["label"],
        "role": definition["role"],
        "route": f"{CONTROL_PROXY_PREFIX}/{node_id}/" if host else "",
        "enabled": bool(host),
        "status": health["status"],
        "reachable": health["reachable"],
        "responding": health["responding"],
        "checked_at": health["checked_at"],
        "latency_ms": health["latency_ms"],
        "http_status": health.get("http_status"),
        "probe": health.get("probe", ""),
        "error": health.get("error", ""),
        "target": f"{host}:{port}" if host else "",
        "note": definition["note"],
        "proof": definition["proof"],
        "reference": node_id == "spartacus",
    }


def control_nodes() -> list[dict[str, object]]:
    nodes: list[dict[str, object]] = []
    for node_id, definition in CONTROL_NODE_DEFINITIONS.items():
        host, port = control_node_target(node_id)
        enabled = bool(host)
        health = control_node_health(node_id, host, port) if enabled else {
            "status": "planned",
            "reachable": False,
            "responding": False,
            "checked_at": "",
            "latency_ms": None,
            "http_status": None,
            "probe": "",
        }
        nodes.append(control_node_row(node_id, definition, host if enabled else "", port, health))
    return nodes


def receipt_status_from_health(health: dict[str, object]) -> str:
    if health.get("responding"):
        return "success"
    if health.get("reachable"):
        return "blocked"
    return "failed"


def receipt_body_from_health(health: dict[str, object]) -> str:
    if health.get("responding"):
        return f"Gateway answered at the app layer with HTTP {health.get('http_status') or 'ok'}."
    if health.get("reachable"):
        return "Railway reached the gateway socket, but the app-layer response did not complete."
    return "Railway could not reach the Spartacus gateway socket."


def append_control_receipt(entry: dict[str, object]) -> None:
    CONTROL_RECEIPTS.parent.mkdir(parents=True, exist_ok=True)
    with CONTROL_RECEIPTS.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(entry, sort_keys=True) + "\n")


def control_receipts(limit: int = 12) -> list[dict[str, object]]:
    if not CONTROL_RECEIPTS.exists():
        return []
    rows: list[dict[str, object]] = []
    for line in CONTROL_RECEIPTS.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            data = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(data, dict):
            rows.append(data)
    return list(reversed(rows[-limit:]))


def refresh_control_node(node_id: str, actor: str) -> tuple[dict[str, object], dict[str, object]]:
    if node_id != "spartacus":
        raise ValueError("only Spartacus refresh is available")
    definition = CONTROL_NODE_DEFINITIONS[node_id]
    host, port = control_node_target(node_id)
    if not host:
        health = {"status": "planned", "reachable": False, "responding": False, "checked_at": utc_now(), "latency_ms": None}
    else:
        health = control_node_health(node_id, host, port, force=True)
    node = control_node_row(node_id, definition, host, port, health)
    created_at = utc_now()
    receipt = {
        "id": f"control-refresh-{int(time.time())}-{secrets.token_hex(3)}",
        "kind": "control_refresh",
        "node_id": node_id,
        "node_label": definition["label"],
        "actor": actor,
        "created_at": created_at,
        "ts": created_at,
        "title": "Spartacus status refreshed",
        "summary": receipt_body_from_health(health),
        "status": receipt_status_from_health(health),
        "state": "read_only",
        "route": node.get("route", ""),
        "probe": health.get("probe", ""),
        "http_status": health.get("http_status"),
        "latency_ms": health.get("latency_ms"),
        "checked_at": health.get("checked_at", ""),
        "reachable": health.get("reachable", False),
        "responding": health.get("responding", False),
        "error": health.get("error", ""),
        "authority": "Glass refreshed the proof only; Spartacus gateway token and device pairing remain the authority.",
    }
    append_control_receipt(receipt)
    return receipt, node


def control_default_url() -> str:
    host, _port = control_node_target("spartacus")
    if REMOTE_REVIEW or not host:
        return ""
    return f"{CONTROL_PROXY_PREFIX}/spartacus/"


def control_proxy_target(node_id: str = "spartacus") -> tuple[str, int]:
    return control_node_target(node_id)


def is_control_proxy_path(path: str) -> bool:
    return path == CONTROL_PROXY_PREFIX or path.startswith(f"{CONTROL_PROXY_PREFIX}/")


def resolve_control_proxy_route(path: str) -> tuple[str, str] | None:
    """Map a request path to a closed registry node and prefix.

    `/control/` and existing absolute asset paths like `/control/assets/*`
    remain Spartacus aliases. Named prefixes like `/control/spartacus/` are
    canonical. Unknown node-looking segments fail closed instead of becoming an
    arbitrary upstream path.
    """
    if not is_control_proxy_path(path):
        return None
    if path == CONTROL_PROXY_PREFIX:
        return "spartacus", CONTROL_PROXY_PREFIX
    remainder = path[len(f"{CONTROL_PROXY_PREFIX}/"):]
    first_segment = remainder.split("/", 1)[0]
    if first_segment in CONTROL_NODE_DEFINITIONS:
        return first_segment, f"{CONTROL_PROXY_PREFIX}/{first_segment}"
    if first_segment in CONTROL_PROXY_LEGACY_ALIAS_SEGMENTS:
        return "spartacus", CONTROL_PROXY_PREFIX
    return None


def control_upstream_path(path: str, prefix: str = CONTROL_PROXY_PREFIX) -> str:
    parsed = urlparse(path)
    suffix = parsed.path[len(prefix):] if parsed.path.startswith(prefix) else parsed.path
    if not suffix:
        suffix = "/"
    if not suffix.startswith("/"):
        suffix = f"/{suffix}"
    return f"{suffix}?{parsed.query}" if parsed.query else suffix


def proxy_request_headers(headers, node_id: str = "spartacus") -> dict[str, str]:
    proxied: dict[str, str] = {}
    host, port = control_proxy_target(node_id)
    for key, value in headers.items():
        lower = key.lower()
        if lower in CONTROL_PROXY_HOP_HEADERS or lower in CONTROL_PROXY_PRIVATE_HEADERS or lower == "host":
            continue
        proxied[key] = value
    proxied["Host"] = f"{host}:{port}"
    return proxied


def proxy_response_headers(headers, prefix: str = CONTROL_PROXY_PREFIX) -> list[tuple[str, str]]:
    proxied: list[tuple[str, str]] = []
    for key, value in headers:
        lower = key.lower()
        if lower in CONTROL_PROXY_HOP_HEADERS or lower == "set-cookie":
            continue
        if lower == "location" and value.startswith("/"):
            value = f"{prefix}{value}"
        proxied.append((key, value))
    return proxied


